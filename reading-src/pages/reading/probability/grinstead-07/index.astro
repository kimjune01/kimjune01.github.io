          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">E[X+Y] = E[X]+E[Y]</td><td class="pr-4 text-green-300">(+ mu-x mu-y)</td><td class="font-sans">Means always add</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">Var(X+Y) = Var(X)+Var(Y)</td><td class="pr-4 text-green-300">(+ var-x var-y)</td><td class="font-sans">Variances add (if independent)</td></tr>
