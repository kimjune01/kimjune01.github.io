        <!-- Trajectory 3 (red) — starts wild, converges -->
        <polyline points="60,40 80,160 100,70 120,95 150,108 180,122 220,110 260,113 300,114 340,115 380,115 420,115 450,115" fill="none" stroke="#ef4444" stroke-width="1.5" stroke-opacity="0.7"/>
