---
import Layout from '../../../layouts/Base.astro';
import ChapterTable from '../../../components/ChapterTable.astro';
import Neighbors from "../../../components/Neighbors.astro";
---

<Layout title="Temporal Compression" favicon="🎞️">
  <main>
    <a href="/reading/" class="text-sm mb-4 inline-block">← back to reading</a>

    <h1>🎞️ Temporal Compression</h1>
    <p class="text-gray-400 mb-2">
      Three fields, one object, no shared vocabulary
    </p>
    <p class="text-gray-400 mb-6">
      Video codecs, temporal graph theory, and sheaf cohomology all work on
      directed dependency graphs with time-ordered composition. Each field has
      tools the others lack. This series maps the vocabulary, identifies the
      one genuine parallel, and states what's open.
    </p>

    <div class="flex justify-center my-6">
      <svg viewBox="0 0 460 340" class="w-full max-w-lg" style="font-family: ui-monospace, monospace;">
        <!-- Top vertex: Codecs -->
        <circle cx="230" cy="50" r="28" fill="currentColor" fill-opacity="0.1" stroke="currentColor" stroke-opacity="0.5" stroke-width="1.5"/>
        <text x="230" y="46" text-anchor="middle" fill="currentColor" font-size="11">Codecs</text>
        <text x="230" y="60" text-anchor="middle" fill="currentColor" fill-opacity="0.4" font-size="8">empirical</text>

        <!-- Bottom-left vertex: TVG -->
        <circle cx="80" cy="290" r="28" fill="currentColor" fill-opacity="0.1" stroke="currentColor" stroke-opacity="0.5" stroke-width="1.5"/>
        <text x="80" y="286" text-anchor="middle" fill="currentColor" font-size="11">TVG</text>
        <text x="80" y="300" text-anchor="middle" fill="currentColor" fill-opacity="0.4" font-size="8">theoretical</text>

        <!-- Bottom-right vertex: Sheaves -->
        <circle cx="380" cy="290" r="28" fill="currentColor" fill-opacity="0.1" stroke="currentColor" stroke-opacity="0.5" stroke-width="1.5"/>
        <text x="380" y="286" text-anchor="middle" fill="currentColor" font-size="11">Sheaves</text>
        <text x="380" y="300" text-anchor="middle" fill="currentColor" fill-opacity="0.4" font-size="8">mathematical</text>

        <!-- Left edge: Codecs - TVG -->
        <line x1="207" y1="72" x2="103" y2="268" stroke="currentColor" stroke-opacity="0.25" stroke-width="1.5"/>
        <text x="130" y="162" text-anchor="middle" fill="currentColor" fill-opacity="0.5" font-size="8">R-D bounds</text>
        <text x="130" y="174" text-anchor="middle" fill="currentColor" fill-opacity="0.5" font-size="8">on journeys</text>

        <!-- Right edge: Codecs - Sheaves -->
        <line x1="253" y1="72" x2="357" y2="268" stroke="currentColor" stroke-opacity="0.25" stroke-width="1.5"/>
        <text x="330" y="162" text-anchor="middle" fill="currentColor" fill-opacity="0.5" font-size="8">checkpoint</text>
        <text x="330" y="174" text-anchor="middle" fill="currentColor" fill-opacity="0.5" font-size="8">spacing from H¹</text>

        <!-- Bottom edge: TVG - Sheaves -->
        <line x1="108" y1="293" x2="352" y2="293" stroke="currentColor" stroke-opacity="0.25" stroke-width="1.5"/>
        <text x="230" y="324" text-anchor="middle" fill="currentColor" fill-opacity="0.5" font-size="8">temporal dynamics in the sheaf</text>

        <!-- Center -->
        <text x="230" y="215" text-anchor="middle" fill="currentColor" fill-opacity="0.3" font-size="9">each edge = a missing theorem</text>
      </svg>
    </div>

    <ChapterTable chapters={[
      { href: "/reading/temporal-compression/ch-01/", title: "The Operator Dictionary", desc: "Three vocabularies for the same structure. This table is the Rosetta Stone." },
      { href: "/reading/temporal-compression/ch-02/", title: "Chain Fragility", desc: "Sequential dependency breaks. Same pattern in all three fields." },
      { href: "/reading/temporal-compression/ch-03/", title: "What Each Field Has", desc: "R-D optimization, impossibility classes, Hodge decomposition. Nobody has all three." },
      { href: "/reading/temporal-compression/ch-04/", title: "The Open Problems", desc: "R-D bounds for journeys. Checkpoint spacing via sheaf cohomology." },
      { href: "/reading/temporal-compression/ch-05/", title: "The Assembly", desc: "Three missing theorems. The roadmap for closing the triangle." },
      { href: "/reading/temporal-compression/ch-06/", title: "The Rosetta Stone", desc: "35 term-pairs from the 2n-3 conjecture. One open question in three fields." },
      { href: "/reading/temporal-compression/ch-07/", title: "The Construction Gap", desc: "22 dead ends and one clean formulation. Where the log factor lives." },
    ]} icon="🎞️" iconClass="text-yellow-300 hover:text-yellow-200" />

    <p class="text-gray-500 text-sm mt-8">
      For agents and reviewers: <a href="https://github.com/kimjune01/junekim-reading/blob/master/src/pages/temporal-compression/CROSSWALK.md">CROSSWALK.md</a> — every claim traced to a validated citation
    </p>

    <p class="text-gray-500 text-sm mt-2">
      Primary sources:
      <a href="https://www.site.uottawa.ca/~flocchin/Papers/tvg-ijpeds.pdf">Casteigts et al. 2012</a> ·
      <a href="https://drops.dagstuhl.de/entities/document/10.4230/LIPIcs.ESA.2022.19">Bilò et al. 2022</a> ·
      <a href="https://arxiv.org/abs/2511.11092">Seely 2025</a> ·
      <a href="https://arxiv.org/abs/1409.6712">Krishnan 2014</a> ·
      <a href="https://web.stanford.edu/class/ee398a/handouts/papers/Sullivan%20-%20RD%20Opt%20for%20Video.pdf">Sullivan &amp; Wiegand 1998</a>
    </p>

    <Neighbors>
      <p class="text-sm text-gray-500 mb-2">Related sections</p>
      <ul class="neighbors">
        <li><a href="/reading/category-theory/">🐱 Category Theory</a> — functors, natural transformations, composition</li>
        <li><a href="/reading/information-theory/">📡 Information Theory</a> — entropy, compression, channel capacity</li>
        <li><a href="/reading/algorithms/">⚙️ Algorithms</a> — graph algorithms, complexity</li>
      </ul>
      <p class="text-sm text-gray-500 mb-2 mt-4">Blog posts</p>
      <ul class="neighbors">
        <li>
          <a href="https://june.kim/consolidation-codec">
            <img src="/reading/jk.png" alt="jk" style="display:inline;height:1em;vertical-align:-0.1em;margin-right:0.2em;"/>
            Consolidation Codec
          </a> — memory as lossy compression
        </li>
        <li>
          <a href="https://june.kim/temporal-compression">
            <img src="/reading/jk.png" alt="jk" style="display:inline;height:1em;vertical-align:-0.1em;margin-right:0.2em;"/>
            Temporal Compression
          </a> — the blog post this section expands
        </li>
      </ul>
    </Neighbors>
  </main>
</Layout>
