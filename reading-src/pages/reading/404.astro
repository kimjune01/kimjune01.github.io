---
import Layout from '../../layouts/Base.astro';
---

<Layout title="Not found" favicon="📚">
  <main class="flex flex-col items-center justify-center" style="min-height: 50vh;">
    <p class="text-6xl mb-4">📚</p>
    <h1 class="text-2xl font-bold mb-2">Page not found</h1>
    <p class="text-gray-400 mb-6">This page doesn't exist or has moved.</p>
    <a href="/reading/" class="bg-zinc-800 px-4 py-2 rounded-lg hover:bg-zinc-700">← Back to Reading</a>
  </main>
</Layout>
