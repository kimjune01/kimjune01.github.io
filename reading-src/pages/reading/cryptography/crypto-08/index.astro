        <rect x="20" y="70" width="80" height="60" rx="4" fill="none" stroke="currentColor" stroke-opacity="0.5" stroke-width="1.5"/>
        <text x="60" y="95" text-anchor="middle" fill="currentColor" font-size="11" fill-opacity="0.7">Document</text>
        <line x1="35" y1="108" x2="85" y2="108" stroke="#71717a" stroke-opacity="0.45" stroke-width="1"/>
        <line x1="35" y1="118" x2="75" y2="118" stroke="#71717a" stroke-opacity="0.45" stroke-width="1"/>

        <!-- Arrow to sign -->
        <line x1="105" y1="100" x2="155" y2="100" stroke="currentColor" stroke-width="1.5"/>
        <polygon points="155,96 163,100 155,104" fill="currentColor"/>

