        <text x="168" y="155" fill="currentColor" font-size="9" fill-opacity="0.4">dy</text>
        <text x="155" y="235" fill="currentColor" font-size="9" fill-opacity="0.4">dx</text>
        <!-- Bounds -->
        <text x="75" y="235" fill="currentColor" font-size="10" fill-opacity="0.4">a</text>
        <text x="248" y="235" fill="currentColor" font-size="10" fill-opacity="0.4">b</text>
      </svg>
