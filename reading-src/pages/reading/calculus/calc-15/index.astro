          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">&nabla; &times; F (curl F)</td><td class="font-sans">Rotation/circulation density</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">&nabla; &middot; F (div F)</td><td class="font-sans">Source/sink density</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">&oint; F &middot; dr</td><td class="font-sans">Circulation around closed curve</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">&oiint; F &middot; dS</td><td class="font-sans">Flux through closed surface</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">d&omega;</td><td class="font-sans">Exterior derivative of differential form</td></tr>
          <tr><td class="py-2 pr-4">&part;M</td><td class="font-sans">Boundary of manifold M</td></tr>
        </tbody>
      </table>
    </div>

