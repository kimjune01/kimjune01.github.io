---
import ChapterTable from "../../../components/ChapterTable.astro";
import Layout from '../../../layouts/Base.astro';
import Neighbors from "../../../components/Neighbors.astro";
---

<Layout title="Calculus" favicon="∫">
  <main>

    <a href="/reading/" class="text-sm mb-4 inline-block">&larr; back to reading</a>

    <h1>∫ Calculus</h1>
    <p class="text-gray-400 mb-2">Based on <a href="https://activecalculus.org/">Active Calculus</a>, licensed <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA</a>.</p>
    <p class="text-gray-400 mb-6">Compressed to runnable code, SVG diagrams, and plain English. Scheme first, Python in the fold.</p>

    <!-- SVG: curve with tangent line and shaded area -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 400 180" class="w-full max-w-md" style="font-family: ui-monospace, monospace;">
        <!-- Shaded area under curve -->
        <path d="M 60 140 Q 120 40 200 100 Q 280 160 340 60 L 340 140 Z" fill="#60a5fa" fill-opacity="0.12"/>
        <!-- Curve -->
        <path d="M 60 140 Q 120 40 200 100 Q 280 160 340 60" fill="none" stroke="#60a5fa" stroke-width="2" stroke-opacity="0.7"/>
        <!-- Tangent line at ~x=200 -->
        <line x1="140" y1="65" x2="260" y2="135" stroke="#f59e0b" stroke-width="1.5" stroke-opacity="0.6"/>
        <!-- Tangent point -->
        <circle cx="200" cy="100" r="4" fill="#f59e0b" fill-opacity="0.7"/>
        <!-- Axis -->
        <line x1="40" y1="140" x2="360" y2="140" stroke="#71717a" stroke-width="1" stroke-opacity="0.45"/>
        <!-- Labels -->
        <text x="355" y="55" text-anchor="end" fill="#60a5fa" font-size="11" fill-opacity="0.5">f(x)</text>
        <text x="265" y="130" fill="#f59e0b" font-size="11" fill-opacity="0.5">tangent</text>
        <text x="200" y="160" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.3">derivative = slope, integral = area</text>
      </svg>
    </div>

    <ChapterTable chapters={[
  { href: "/reading/calculus/calc-01/", title: "Functions and Graphs", desc: "Domain, range, composition, inverses: the vocabulary everything else builds on" },
  { href: "/reading/calculus/calc-02/", title: "Trigonometry", desc: "Unit circle, sin/cos/tan, identities, inverse trig: periodic functions decoded" },
  { href: "/reading/calculus/calc-03/", title: "Limits and Continuity", desc: "What 'approaching' means, made precise with epsilon-delta" },
  { href: "/reading/calculus/calc-04/", title: "The Derivative", desc: "Instantaneous rate of change as a limit of secant slopes" },
  { href: "/reading/calculus/calc-05/", title: "Derivative Rules", desc: "Power, product, quotient, chain: the shortcuts that make differentiation mechanical" },
  { href: "/reading/calculus/calc-06/", title: "Applications of Derivatives", desc: "Optimization, related rates, curve sketching: what derivatives are for" },
  { href: "/reading/calculus/calc-07/", title: "The Integral", desc: "Riemann sums, definite integrals, and the Fundamental Theorem that ties it all together" },
  { href: "/reading/calculus/calc-08/", title: "Techniques of Integration", desc: "Substitution, parts, partial fractions: the toolkit for antiderivatives" },
  { href: "/reading/calculus/calc-09/", title: "Applications of Integrals", desc: "Area, volume, arc length, work: what integrals are for" },
  { href: "/reading/calculus/calc-10/", title: "Vectors and Geometry", desc: "Dot products, cross products, lines, planes: calculus goes multidimensional" },
  { href: "/reading/calculus/calc-11/", title: "Partial Derivatives", desc: "Derivatives of functions with multiple inputs: hold one variable fixed, vary the other" },
  { href: "/reading/calculus/calc-12/", title: "Optimization", desc: "Lagrange multipliers and gradient descent: finding extrema with constraints" },
  { href: "/reading/calculus/calc-13/", title: "Multiple Integrals", desc: "Double and triple integrals: area becomes volume, volume becomes mass" },
  { href: "/reading/calculus/calc-14/", title: "Line and Surface Integrals", desc: "Integrating along curves and over surfaces: work, flux, circulation" },
  { href: "/reading/calculus/calc-15/", title: "Fundamental Theorems", desc: "Green, Stokes, Divergence: the boundary-interior duality that unifies calculus" }
]} icon="∫" iconClass="text-yellow-300 hover:text-yellow-200" />


    <p class="text-gray-500 text-sm mt-8">📺 Video lectures: <a href="https://www.3blue1brown.com/topics/calculus">3Blue1Brown: Essence of Calculus</a></p>

    <Neighbors>
    <ul class="neighbors">
      <li><a href="/reading/real-analysis/">∞ Real Analysis</a> &mdash; the rigorous foundations that justify what calculus does</li>
      <li><a href="/reading/linear-algebra/">📐 Linear Algebra</a> &mdash; multivariable calculus and linear transformations share the same substrate</li>
      <li><a href="/reading/physics/">⚛ Physics</a> &mdash; calculus was invented to describe motion</li>
      <li><a href="/reading/machine-learning/">🤖 Machine Learning</a> &mdash; gradient descent lives in calculus</li>
      <li><a href="/reading/control/">🎛 Control Theory</a> &mdash; differential equations throughout</li>
    </ul>
    </Neighbors>

  </main>
</Layout>
