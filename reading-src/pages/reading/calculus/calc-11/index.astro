          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">&part;f/&part;x</td><td class="font-sans">Partial derivative w.r.t. x</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">&nabla;f = (f_x, f_y)</td><td class="font-sans">Gradient vector</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">D_u f = &nabla;f &middot; u</td><td class="font-sans">Directional derivative</td></tr>
          <tr><td class="py-2 pr-4">z = f(a,b) + f_x(x&minus;a) + f_y(y&minus;b)</td><td class="font-sans">Tangent plane</td></tr>
