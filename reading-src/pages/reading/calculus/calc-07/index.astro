          <tr><td class="py-2 pr-4">&#x222B; f(x)dx</td><td class="pr-4 text-green-300">F(x) + C</td><td class="font-sans">Indefinite integral (antiderivative)</td></tr>
        </tbody>
      </table>
    </div>

