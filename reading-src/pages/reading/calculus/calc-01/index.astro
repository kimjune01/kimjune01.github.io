    <a href="/reading/calculus/" class="text-sm mb-4 inline-block">&larr; back to calculus</a>

    <h1>Functions and Graphs</h1>
    <p class="text-gray-400 text-sm mb-6">Active Calculus (CC BY-SA) · <a href="https://activecalculus.org/">activecalculus.org</a></p>

    <div class="bg-zinc-800 rounded-lg p-5 mb-8 callout">
      <p class="text-lg" style="max-width:none">A <strong>function</strong> is a rule that assigns each input exactly one output. Domain is what goes in, range is what comes out. Composition chains functions; inverses undo them. Every concept in calculus starts here.</p>
    </div>

    <!-- SVG: function with domain/range arrows -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 360 160" class="w-full max-w-sm" style="font-family: ui-monospace, monospace;">
        <!-- Domain oval -->
        <ellipse cx="80" cy="80" rx="55" ry="60" fill="none" stroke="#60a5fa" stroke-width="1.5" stroke-opacity="0.4"/>
        <text x="80" y="150" text-anchor="middle" fill="#60a5fa" font-size="11" fill-opacity="0.6">Domain</text>
        <!-- Range oval -->
        <ellipse cx="280" cy="80" rx="55" ry="60" fill="none" stroke="#f59e0b" stroke-width="1.5" stroke-opacity="0.4"/>
        <text x="280" y="150" text-anchor="middle" fill="#f59e0b" font-size="11" fill-opacity="0.6">Range</text>
        <!-- Points in domain -->
        <circle cx="70" cy="55" r="3" fill="#60a5fa" fill-opacity="0.6"/>
        <text x="60" y="52" text-anchor="end" fill="#60a5fa" font-size="10" fill-opacity="0.5">1</text>
        <circle cx="85" cy="80" r="3" fill="#60a5fa" fill-opacity="0.6"/>
        <text x="75" y="77" text-anchor="end" fill="#60a5fa" font-size="10" fill-opacity="0.5">2</text>
        <circle cx="70" cy="105" r="3" fill="#60a5fa" fill-opacity="0.6"/>
        <text x="60" y="102" text-anchor="end" fill="#60a5fa" font-size="10" fill-opacity="0.5">3</text>
        <!-- Points in range -->
        <circle cx="275" cy="60" r="3" fill="#f59e0b" fill-opacity="0.6"/>
        <text x="290" y="57" fill="#f59e0b" font-size="10" fill-opacity="0.5">1</text>
        <circle cx="275" cy="85" r="3" fill="#f59e0b" fill-opacity="0.6"/>
        <text x="290" y="82" fill="#f59e0b" font-size="10" fill-opacity="0.5">4</text>
        <circle cx="275" cy="110" r="3" fill="#f59e0b" fill-opacity="0.6"/>
        <text x="290" y="107" fill="#f59e0b" font-size="10" fill-opacity="0.5">9</text>
        <!-- Arrows -->
        <line x1="75" y1="55" x2="270" y2="60" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <polygon points="270,57 264,55 266,62" fill="currentColor" fill-opacity="0.3"/>
        <line x1="90" y1="80" x2="270" y2="85" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <polygon points="270,82 264,80 266,87" fill="currentColor" fill-opacity="0.3"/>
        <line x1="75" y1="105" x2="270" y2="110" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <polygon points="270,107 264,105 266,112" fill="currentColor" fill-opacity="0.3"/>
