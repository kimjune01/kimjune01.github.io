          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">e&#x02E3;</td><td class="pr-4 text-green-300">(exp x)</td><td class="pr-4 text-blue-300">math.exp(x)</td><td class="font-sans">Exponential</td></tr>
          <tr><td class="py-2 pr-4">ln(x)</td><td class="pr-4 text-green-300">(log x)</td><td class="pr-4 text-blue-300">math.log(x)</td><td class="font-sans">Natural logarithm</td></tr>
