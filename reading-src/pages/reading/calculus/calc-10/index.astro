          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">u &times; v</td><td class="font-sans">Cross product (vector, R3 only)</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">|v|</td><td class="font-sans">Magnitude / length</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">r(t) = P + td</td><td class="font-sans">Parametric line</td></tr>
          <tr><td class="py-2 pr-4">n &middot; (r &minus; P) = 0</td><td class="font-sans">Equation of a plane</td></tr>
        </tbody>
      </table>
    </div>

