        <text x="120" y="18" text-anchor="middle" fill="#f59e0b" font-size="10" fill-opacity="0.7">VaR (95%)</text>
        <!-- Shaded tail area -->
        <path d="M60,158 Q80,157 100,153 Q110,148 120,143 L120,160 Z" fill="#ef4444" fill-opacity="0.15"/>
        <!-- CVaR marker -->
