        <polygon points="215,47 215,53 222,50" fill="currentColor" fill-opacity="0.3"/>
        <!-- Annotation -->
        <text x="200" y="100" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.4">correction term</text>
        <!-- Key insight -->
        <rect x="80" y="120" width="240" height="40" rx="6" fill="none" stroke="#34d399" stroke-width="1" stroke-opacity="0.3"/>
        <text x="200" y="140" text-anchor="middle" fill="#34d399" font-size="11" fill-opacity="0.6">(dB)&#xB2; = dt   (quadratic variation)</text>
