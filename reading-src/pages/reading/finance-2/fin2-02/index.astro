        <text x="100" y="65" text-anchor="middle" fill="#60a5fa" font-size="13" fill-opacity="0.5">df = f&#x2032; dx</text>
        <!-- Box: Ito calculus -->
        <rect x="220" y="20" width="160" height="60" rx="6" fill="none" stroke="#f59e0b" stroke-width="1.5" stroke-opacity="0.4"/>
        <text x="300" y="45" text-anchor="middle" fill="#f59e0b" font-size="11" fill-opacity="0.7">Ito&#x2019;s Lemma</text>
        <text x="300" y="65" text-anchor="middle" fill="#f59e0b" font-size="13" fill-opacity="0.5">df = f&#x2032;dX + &#xBD;f&#x2033;(dX)&#xB2;</text>
        <!-- Arrow between -->
