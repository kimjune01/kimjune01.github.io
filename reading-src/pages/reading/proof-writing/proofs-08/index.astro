        <text x="115" y="125" fill="currentColor" font-size="11" fill-opacity="0.4">0 0 6</text>
        <text x="160" y="125" fill="#f87171" font-size="12" font-weight="bold">2</text>
        <text x="175" y="125" fill="currentColor" font-size="11" fill-opacity="0.4">9 ...</text>

        <text x="60" y="150" fill="currentColor" font-size="11" fill-opacity="0.4">r5 = 0.</text>
        <text x="115" y="150" fill="currentColor" font-size="11" fill-opacity="0.4">8 3 0 7</text>
        <text x="175" y="150" fill="#f87171" font-size="12" font-weight="bold">7</text>
        <text x="190" y="150" fill="currentColor" font-size="11" fill-opacity="0.4">...</text>

        <!-- Diagonal line -->
