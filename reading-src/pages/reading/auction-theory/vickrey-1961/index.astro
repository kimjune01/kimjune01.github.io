          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">b_i = v_i</td><td class="pr-4 text-green-300">(payoff value value others)</td><td class="font-sans">Truthful bidding</td></tr>
          <tr><td class="py-2 pr-4">p = max(b_j, j != i)</td><td class="pr-4 text-green-300">(apply max other-bids)</td><td class="font-sans">Payment = second-highest bid</td></tr>
