---

<Layout title="Hefferon Ch.4 — Determinants" favicon="📐">
  <main>

    <a href="/reading/linear-algebra/" class="text-sm mb-4 inline-block">← back to linear algebra</a>

    <h1>Determinants</h1>
    <p class="text-gray-400 text-sm mb-6">Jim Hefferon · GFDL + CC BY-SA 2.5 · <a href="https://hefferon.net/linearalgebra/">Linear Algebra</a></p>

    <div class="bg-zinc-800 rounded-lg p-5 mb-8 callout">
      <p class="text-lg" style="max-width:none">The <strong>determinant</strong> is a single number that captures whether a square matrix is invertible and how it scales volume. det(A) = 0 means the map collapses a dimension. det(AB) = det(A) * det(B). Geometrically, the determinant of a 2-by-2 matrix is the signed area of the parallelogram spanned by its columns.</p>
    </div>

    <!-- 1. Definition -->
    <h3>Cofactor expansion</h3>
    <p>The determinant of a 1-by-1 matrix is its single entry. For larger matrices, expand along any row or column: multiply each entry by its <strong>cofactor</strong> (the determinant of the submatrix with that row and column deleted, times a sign). The result is the same regardless of which row or column you pick.</p>

    <!-- SVG: interactive parallelogram — drag vector tips -->
    <div class="flex justify-center my-6">
      <svg id="det-pgram" viewBox="0 0 320 250" class="w-full max-w-sm" style="font-family: ui-monospace, monospace; cursor: pointer;">
        <!-- Axes -->
        <line x1="40" y1="200" x2="300" y2="200" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>
        <line x1="40" y1="20" x2="40" y2="200" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>
        <!-- Origin -->
        <circle cx="40" cy="200" r="2.5" fill="currentColor" fill-opacity="0.3"/>
        <!-- Parallelogram -->
        <polygon id="det-pgon" fill="#60a5fa" fill-opacity="0.08" stroke="#60a5fa" stroke-width="1.5" stroke-opacity="0.4"/>
        <!-- Vector a — blue -->
        <line id="det-va" x1="40" y1="200" stroke="#60a5fa" stroke-width="2"/>
        <circle id="det-da" r="6" fill="#60a5fa" fill-opacity="0.8" style="cursor: grab;"/>
        <text id="det-la" fill="#60a5fa" font-size="11"></text>
        <!-- Vector b — amber -->
        <line id="det-vb" x1="40" y1="200" stroke="#f59e0b" stroke-width="2"/>
        <circle id="det-db" r="6" fill="#f59e0b" fill-opacity="0.8" style="cursor: grab;"/>
        <text id="det-lb" fill="#f59e0b" font-size="11"></text>
        <!-- Area + formula -->
        <text id="det-area" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.6"></text>
        <text id="det-formula" x="160" y="240" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.35"></text>
      </svg>
    </div>
    <script is:inline>
    (function() {
      var OX = 40, OY = 200, S = 60; // scale: 1 unit = 60px
      var ax = 3, ay = 1, bx = 1, by = 2;
      var svg = document.getElementById('det-pgram');
      var pgon = document.getElementById('det-pgon');
      var va = document.getElementById('det-va');
      var da = document.getElementById('det-da');
      var la = document.getElementById('det-la');
      var vb = document.getElementById('det-vb');
      var db = document.getElementById('det-db');
      var lb = document.getElementById('det-lb');
      var areaT = document.getElementById('det-area');
      var formulaT = document.getElementById('det-formula');

      function px(vx) { return OX + vx * S; }
      function py(vy) { return OY - vy * S; }

      function update() {
        var pax = px(ax), pay = py(ay), pbx = px(bx), pby = py(by);
        var pcx = px(ax + bx), pcy = py(ay + by);
        pgon.setAttribute('points', OX+','+OY+' '+pax+','+pay+' '+pcx+','+pcy+' '+pbx+','+pby);
        va.setAttribute('x2', pax); va.setAttribute('y2', pay);
        da.setAttribute('cx', pax); da.setAttribute('cy', pay);
        vb.setAttribute('x2', pbx); vb.setAttribute('y2', pby);
        db.setAttribute('cx', pbx); db.setAttribute('cy', pby);
        la.setAttribute('x', (OX + pax) / 2 + (ay > 0 ? 0 : 0));
        la.setAttribute('y', (OY + pay) / 2 + 18);
        la.textContent = 'a = (' + ax.toFixed(1) + ', ' + ay.toFixed(1) + ')';
        lb.setAttribute('x', (OX + pbx) / 2 - 5);
        lb.setAttribute('y', (OY + pby) / 2 - 8);
        lb.textContent = 'b = (' + bx.toFixed(1) + ', ' + by.toFixed(1) + ')';
        var det = ax * by - ay * bx;
        areaT.setAttribute('x', (OX + pcx) / 2);
        areaT.setAttribute('y', (OY + pcy) / 2 + 5);
        areaT.textContent = 'area = |det| = ' + Math.abs(det).toFixed(1);
        formulaT.textContent = 'det = ' + ax.toFixed(1) + '\u00D7' + by.toFixed(1) + ' \u2212 ' + ay.toFixed(1) + '\u00D7' + bx.toFixed(1) + ' = ' + det.toFixed(1);
      }

      function svgPt(e) {
        var pt = svg.createSVGPoint();
        var ctm = svg.getScreenCTM();
        if (e.touches) e = e.touches[0];
        pt.x = e.clientX; pt.y = e.clientY;
        return pt.matrixTransform(ctm.inverse());
      }

      var drag = null;
      function dist(cx, cy, pt) { var dx = cx - pt.x, dy = cy - pt.y; return dx*dx + dy*dy; }

      function onDown(e) {
        var pt = svgPt(e);
        if (dist(px(ax), py(ay), pt) < dist(px(bx), py(by), pt)) drag = 'a';
        else drag = 'b';
        onMove(e);
        e.preventDefault();
      }
      function onMove(e) {
        if (!drag) return;
        var pt = svgPt(e);
        var vx = Math.round((pt.x - OX) / S * 2) / 2; // snap to 0.5
        var vy = Math.round((OY - pt.y) / S * 2) / 2;
        vx = Math.max(-1, Math.min(4, vx));
        vy = Math.max(-1, Math.min(3.5, vy));
        if (drag === 'a') { ax = vx; ay = vy; }
        else { bx = vx; by = vy; }
        update();
        e.preventDefault();
      }
      function onUp() { drag = null; }

      svg.addEventListener('mousedown', onDown);
      svg.addEventListener('mousemove', onMove);
      window.addEventListener('mouseup', onUp);
      svg.addEventListener('touchstart', onDown, {passive: false});
      svg.addEventListener('touchmove', onMove, {passive: false});
      window.addEventListener('touchend', onUp);

      update();
    })();
    </script>

    <SchemeRepl client:visible initialCode={`; Determinant of a 2x2 matrix: ad - bc

(define (det2 a b c d)
  (- (* a d) (* b c)))

(display "det((3,1),(1,2)) = ")
(display (det2 3 1 1 2))
(newline)
; 3*2 - 1*1 = 5

; Determinant of a 3x3 matrix by cofactor expansion along row 1
(define (det3 m)
  (let ((a (list-ref (list-ref m 0) 0))
        (b (list-ref (list-ref m 0) 1))
        (c (list-ref (list-ref m 0) 2))
        (d (list-ref (list-ref m 1) 0))
        (e (list-ref (list-ref m 1) 1))
        (f (list-ref (list-ref m 1) 2))
        (g (list-ref (list-ref m 2) 0))
        (h (list-ref (list-ref m 2) 1))
        (i (list-ref (list-ref m 2) 2)))
    (+ (* a (det2 e f h i))
       (- (* b (det2 d f g i)))
       (* c (det2 d e g h)))))

(define A '((1 2 3)
            (4 5 6)
            (7 8 9)))

(display "det(A) = ")
(display (det3 A))
; Should be 0 (rows are in arithmetic progression)
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# 2x2 and 3x3 determinants
def det2(a, b, c, d):
    return a*d - b*c

def det3(m):
    a,b,c = m[0]
    d,e,f = m[1]
    g,h,i = m[2]
    return a*det2(e,f,h,i) - b*det2(d,f,g,i) + c*det2(d,e,g,h)

print(f"det 2x2: {det2(3,1,1,2)}")      # 5
A = [[1,2,3],[4,5,6],[7,8,9]]
print(f"det 3x3: {det3(A)}")             # 0
`} />
    </div>


    <!-- 2. Properties -->
    <h3>Properties of determinants</h3>
    <p>Three key properties. First, <strong>det(AB) = det(A) * det(B)</strong>: the determinant is multiplicative. Second, row operations have predictable effects: swapping rows flips the sign, scaling a row multiplies the determinant, adding a multiple of one row to another leaves it unchanged. Third, det(A) is nonzero if and only if A is invertible.</p>

    <SchemeRepl client:visible initialCode={`; Multiplicativity: det(AB) = det(A) * det(B)

(define (det2 a b c d) (- (* a d) (* b c)))

; A = ((2 1) (0 3)), det(A) = 6
; B = ((1 4) (2 5)), det(B) = -3
(define detA (det2 2 1 0 3))
(define detB (det2 1 4 2 5))

(display "det(A) = ") (display detA) (newline)
(display "det(B) = ") (display detB) (newline)
(display "det(A)*det(B) = ") (display (* detA detB)) (newline)

; Compute AB manually:
; AB = ((2*1+1*2, 2*4+1*5), (0*1+3*2, 0*4+3*5))
;    = ((4, 13), (6, 15))
(define detAB (det2 4 13 6 15))
(display "det(AB) = ") (display detAB) (newline)
; 4*15 - 13*6 = 60 - 78 = -18 = 6 * (-3)

(display "Equal? ") (display (= (* detA detB) detAB))
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# Multiplicativity: det(AB) = det(A)*det(B)
det2 = lambda a,b,c,d: a*d - b*c

detA = det2(2, 1, 0, 3)  # 6
detB = det2(1, 4, 2, 5)  # -3

# AB = ((4, 13), (6, 15))
detAB = det2(4, 13, 6, 15)  # -18

print("det(A) = " + str(detA))
print("det(B) = " + str(detB))
print("det(A)*det(B) = " + str(detA * detB))
print("det(AB) = " + str(detAB))
print("Equal? " + str(detA * detB == detAB))
`} />
    </div>


    <!-- 3. Row operations -->
    <h3>Row operations and determinants</h3>
    <p>Row operations are the algorithmic path to computing determinants. Reduce to echelon form, track the sign flips from row swaps, and multiply the diagonal entries. This is O(n^3), far better than cofactor expansion's O(n!).</p>

    <SchemeRepl client:visible initialCode={`; Computing det via row reduction.
; A = ((2 6) (1 4))
; R2 <- R2 - (1/2)*R1: ((2 6) (0 1))
; det = product of pivots = 2 * 1 = 2

(define (det2 a b c d) (- (* a d) (* b c)))

; Direct computation:
(display "Direct: det = ")
(display (det2 2 6 1 4))
(newline)

; Via row reduction:
; After R2 <- R2 - (1/2)*R1, pivots are 2 and 1.
; No row swaps, so sign is +1.
(display "Via pivots: 2 * 1 = ")
(display (* 2 1))
(newline)

; With a row swap: swap R1 and R2
; ((1 4) (2 6)) — one swap, sign flips
; R2 <- R2 - 2*R1: ((1 4) (0 -2))
; det = (-1) * 1 * (-2) = 2
(display "With swap: (-1) * 1 * (-2) = ")
(display (* -1 1 -2))
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# Determinant via row reduction
det2 = lambda a,b,c,d: a*d - b*c

print("Direct: det = " + str(det2(2, 6, 1, 4)))

# Via pivots after R2 <- R2 - (1/2)*R1: pivots 2 and 1
print("Via pivots: 2 * 1 = " + str(2 * 1))

# With a row swap: sign flips
# Pivots become 1, -2; one swap
print("With swap: (-1) * 1 * (-2) = " + str((-1) * 1 * (-2)))
`} />
    </div>


    <!-- 4. Geometric interpretation -->
    <h3>Geometric interpretation</h3>
    <p>In 2D, |det(A)| is the area of the parallelogram spanned by the columns of A. In 3D, it is the volume of the parallelepiped. A negative determinant means the transformation reverses orientation. Zero determinant means the columns are coplanar, and the map squashes a dimension.</p>

    <SchemeRepl client:visible initialCode={`; Signed area of a parallelogram
; Columns (2,0) and (0,3): axis-aligned rectangle, area = 6

(define (det2 a b c d) (- (* a d) (* b c)))

(display "Rectangle (2,0)x(0,3): area = ")
(display (det2 2 0 0 3))
(newline)

; Shear: columns (1,0) and (1,1)
; Parallelogram, area = 1 (shearing preserves area)
(display "Shear (1,0)x(1,1): area = ")
(display (det2 1 1 0 1))
(newline)

; Collapse: columns (1,2) and (2,4) — dependent
(display "Collapsed (1,2)x(2,4): area = ")
(display (det2 1 2 2 4))
(newline)
; Zero — the parallelogram degenerates to a line.

; Reflection flips sign: columns (0,1) and (1,0)
(display "Reflection (0,1)x(1,0): signed area = ")
(display (det2 0 1 1 0))
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# Signed area of parallelograms
det2 = lambda a,b,c,d: a*d - b*c

print("Rectangle (2,0)x(0,3): area = " + str(det2(2, 0, 0, 3)))
print("Shear (1,0)x(1,1): area = " + str(det2(1, 1, 0, 1)))
print("Collapsed (1,2)x(2,4): area = " + str(det2(1, 2, 2, 4)))
print("Reflection (0,1)x(1,0): signed area = " + str(det2(0, 1, 1, 0)))
`} />
    </div>


