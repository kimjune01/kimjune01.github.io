        <text x="70" y="134" text-anchor="end" fill="#60a5fa" font-size="9" fill-opacity="0.6">+1 again</text>
        <circle cx="300" cy="130" r="4" fill="#f59e0b" fill-opacity="0.6"/>
        <text x="330" y="134" fill="#f59e0b" font-size="9" fill-opacity="0.6">+3</text>
        <!-- Converge -->
        <line x1="103" y1="134" x2="197" y2="170" stroke="#60a5fa" stroke-width="1" stroke-opacity="0.4"/>
        <line x1="297" y1="134" x2="203" y2="170" stroke="#f59e0b" stroke-width="1" stroke-opacity="0.4"/>
        <!-- Merged state -->
