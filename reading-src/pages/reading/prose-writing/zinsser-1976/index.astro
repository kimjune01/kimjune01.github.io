    <h1>On Writing Well</h1>
    <p class="text-gray-400 text-sm mb-6">William Zinsser &middot; 1976 &middot; Copyrighted &mdash; available in bookstores and libraries; no full text online</p>

    <div class="bg-zinc-800 rounded-lg p-5 mb-8 callout">
      <p class="text-lg" style="max-width:none">Strunk said omit needless words. Zinsser asked: why are they there? His answer: because the writer hasn&rsquo;t finished thinking. Clutter is a symptom of unclear thought. The cure is rewriting, not once, but until every sentence says exactly what you mean and nothing else.</p>
    </div>

    <!-- SVG: Zinsser's causal diagnosis — clutter traces back to unclear thinking -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 480 220" class="w-full max-w-lg" style="font-family: ui-monospace, monospace;">

        <!-- Strunk's view (surface) -->
        <text x="240" y="18" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.4">Strunk sees this</text>

        <!-- Cluttered sentence -->
        <rect x="80" y="28" width="320" height="30" rx="4" fill="#a1a1aa" fill-opacity="0.06" stroke="currentColor" stroke-width="1" stroke-opacity="0.2"/>
        <text x="100" y="47" fill="currentColor" font-size="8" fill-opacity="0.25">I think what I'm trying to say is that</text>
        <text x="320" y="47" fill="#ef4444" font-size="8" fill-opacity="0.5">needless words</text>

        <!-- Strunk's fix: delete -->
        <line x1="420" y1="43" x2="450" y2="43" stroke="#ef4444" stroke-width="1" stroke-opacity="0.4"/>
        <text x="455" y="46" fill="#ef4444" font-size="8" fill-opacity="0.5">cut</text>

        <!-- Divider -->
        <line x1="60" y1="75" x2="420" y2="75" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.2"/>

        <!-- Zinsser's view (cause) -->
        <text x="240" y="95" text-anchor="middle" fill="#a78bfa" font-size="10" fill-opacity="0.6">Zinsser asks why</text>

        <!-- Causal chain: unclear thought → clutter → rewrite → clear thought -->
        <rect x="30" y="110" width="95" height="40" rx="4" fill="#a78bfa" fill-opacity="0.06" stroke="#a78bfa" stroke-width="1" stroke-opacity="0.3"/>
        <text x="77" y="128" text-anchor="middle" fill="#a78bfa" font-size="8" fill-opacity="0.6">unclear</text>
        <text x="77" y="140" text-anchor="middle" fill="#a78bfa" font-size="8" fill-opacity="0.6">thought</text>

        <!-- Arrow: produces -->
        <line x1="128" y1="130" x2="155" y2="130" stroke="#a78bfa" stroke-width="1" stroke-opacity="0.3"/>
        <polygon points="153,127 160,130 153,133" fill="#a78bfa" fill-opacity="0.3"/>
        <text x="143" y="122" text-anchor="middle" fill="currentColor" font-size="7" fill-opacity="0.2">produces</text>

        <rect x="163" y="110" width="75" height="40" rx="4" fill="#ef4444" fill-opacity="0.06" stroke="#ef4444" stroke-width="1" stroke-opacity="0.25"/>
        <text x="200" y="134" text-anchor="middle" fill="#ef4444" font-size="8" fill-opacity="0.5">clutter</text>

        <!-- Arrow: rewrite -->
        <line x1="241" y1="130" x2="268" y2="130" stroke="#a78bfa" stroke-width="1" stroke-opacity="0.3"/>
        <polygon points="266,127 273,130 266,133" fill="#a78bfa" fill-opacity="0.3"/>
        <text x="256" y="122" text-anchor="middle" fill="currentColor" font-size="7" fill-opacity="0.2">rewrite</text>

        <rect x="276" y="110" width="75" height="40" rx="4" fill="#a78bfa" fill-opacity="0.06" stroke="#a78bfa" stroke-width="1" stroke-opacity="0.3"/>
        <text x="313" y="128" text-anchor="middle" fill="#a78bfa" font-size="8" fill-opacity="0.6">clearer</text>
        <text x="313" y="140" text-anchor="middle" fill="#a78bfa" font-size="8" fill-opacity="0.6">thought</text>

        <!-- Arrow: produces -->
        <line x1="354" y1="130" x2="381" y2="130" stroke="#a78bfa" stroke-width="1" stroke-opacity="0.3"/>
        <polygon points="379,127 386,130 379,133" fill="#a78bfa" fill-opacity="0.3"/>
        <text x="369" y="122" text-anchor="middle" fill="currentColor" font-size="7" fill-opacity="0.2">produces</text>

        <rect x="389" y="110" width="75" height="40" rx="4" fill="#34d399" fill-opacity="0.08" stroke="#34d399" stroke-width="1" stroke-opacity="0.3"/>
        <text x="426" y="128" text-anchor="middle" fill="#34d399" font-size="8" fill-opacity="0.6">clean</text>
        <text x="426" y="140" text-anchor="middle" fill="#34d399" font-size="8" fill-opacity="0.6">prose</text>

        <!-- Feedback loop arrow from "clearer thought" back to rewrite -->
        <path d="M 313 153 C 313 175, 200 175, 200 153" fill="none" stroke="#a78bfa" stroke-width="0.8" stroke-opacity="0.25" stroke-dasharray="3,3"/>
        <polygon points="197,155 200,148 203,155" fill="#a78bfa" fill-opacity="0.25"/>
        <text x="256" y="186" text-anchor="middle" fill="currentColor" font-size="7" fill-opacity="0.2">repeat until the thought is finished</text>

        <!-- Bottom note -->
        <text x="240" y="210" text-anchor="middle" fill="currentColor" font-size="8" fill-opacity="0.2">the fix is upstream of the sentence</text>
      </svg>
