<Layout title="Quintilian — Institutio Oratoria" favicon="✍️">
  <main>

    <a href="/reading/prose-writing/" class="text-sm mb-4 inline-block">&larr; back to prose writing</a>

    <h1>Institutio Oratoria</h1>
    <p class="text-gray-400 text-sm mb-6">Quintilian · ~95 AD · <a href="https://penelope.uchicago.edu/Thayer/E/Roman/Texts/Quintilian/Institutio_Oratoria/home.html">Full text (LacusCurtius, public domain)</a></p>

    <div class="bg-zinc-800 rounded-lg p-5 mb-8 callout">
      <p class="text-lg" style="max-width:none">The first complete curriculum for making someone articulate. What to say, how to find it, arrange it, phrase it, remember it, and deliver it. Five stages, from childhood to the courtroom. The rhetorical canon that every writing course still follows, whether it knows it or not.</p>
    </div>

    <!-- SVG: The five canons pipeline -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 560 140" class="w-full max-w-xl" style="font-family: ui-monospace, monospace;">
        <!-- Title -->
        <text x="280" y="16" text-anchor="middle" fill="currentColor" font-size="11" fill-opacity="0.5">The Five Canons of Rhetoric</text>

        <!-- Inventio -->
        <rect x="10" y="30" width="96" height="40" rx="5" fill="#60a5fa" fill-opacity="0.15" stroke="#60a5fa" stroke-width="1.2" stroke-opacity="0.5"/>
        <text x="58" y="48" text-anchor="middle" fill="#60a5fa" font-size="10">Inventio</text>
        <text x="58" y="62" text-anchor="middle" fill="currentColor" font-size="8" fill-opacity="0.4">Finding</text>

        <!-- Arrow 1 -->
        <line x1="110" y1="50" x2="122" y2="50" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.3"/>
        <polygon points="122,47 128,50 122,53" fill="currentColor" fill-opacity="0.3"/>

        <!-- Dispositio -->
        <rect x="130" y="30" width="96" height="40" rx="5" fill="#34d399" fill-opacity="0.15" stroke="#34d399" stroke-width="1.2" stroke-opacity="0.5"/>
        <text x="178" y="48" text-anchor="middle" fill="#34d399" font-size="10">Dispositio</text>
        <text x="178" y="62" text-anchor="middle" fill="currentColor" font-size="8" fill-opacity="0.4">Arranging</text>

        <!-- Arrow 2 -->
        <line x1="230" y1="50" x2="242" y2="50" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.3"/>
        <polygon points="242,47 248,50 242,53" fill="currentColor" fill-opacity="0.3"/>

        <!-- Elocutio -->
        <rect x="250" y="30" width="96" height="40" rx="5" fill="#f59e0b" fill-opacity="0.15" stroke="#f59e0b" stroke-width="1.2" stroke-opacity="0.5"/>
        <text x="298" y="48" text-anchor="middle" fill="#f59e0b" font-size="10">Elocutio</text>
        <text x="298" y="62" text-anchor="middle" fill="currentColor" font-size="8" fill-opacity="0.4">Styling</text>

        <!-- Arrow 3 -->
        <line x1="350" y1="50" x2="362" y2="50" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.3"/>
        <polygon points="362,47 368,50 362,53" fill="currentColor" fill-opacity="0.3"/>

        <!-- Memoria -->
        <rect x="370" y="30" width="96" height="40" rx="5" fill="#a78bfa" fill-opacity="0.15" stroke="#a78bfa" stroke-width="1.2" stroke-opacity="0.5"/>
        <text x="418" y="48" text-anchor="middle" fill="#a78bfa" font-size="10">Memoria</text>
        <text x="418" y="62" text-anchor="middle" fill="currentColor" font-size="8" fill-opacity="0.4">Memorizing</text>

        <!-- Arrow 4 -->
        <line x1="470" y1="50" x2="482" y2="50" stroke="currentColor" stroke-width="1.2" stroke-opacity="0.3"/>
        <polygon points="482,47 488,50 482,53" fill="currentColor" fill-opacity="0.3"/>

        <!-- Pronuntiatio -->
