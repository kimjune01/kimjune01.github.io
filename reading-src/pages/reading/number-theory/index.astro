        <text x="354" y="187" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">36</text>
      </svg>
    </div>

    <ChapterTable chapters={[
  { href: "/reading/number-theory/numthy-01/", title: "Divisibility", desc: "The divides relation, division algorithm, GCD, and the Euclidean algorithm" },
  { href: "/reading/number-theory/numthy-02/", title: "Primes", desc: "Fundamental theorem of arithmetic, infinitude of primes, sieve of Eratosthenes" },
  { href: "/reading/number-theory/numthy-03/", title: "Congruences", desc: "Modular arithmetic, congruence classes, and solving linear congruences" },
  { href: "/reading/number-theory/numthy-04/", title: "Euler and Fermat", desc: "Euler's totient, Fermat's little theorem, and fast modular exponentiation" },
  { href: "/reading/number-theory/numthy-05/", title: "Chinese Remainder Theorem", desc: "Solving systems of congruences with a constructive algorithm" },
  { href: "/reading/number-theory/numthy-06/", title: "Quadratic Residues", desc: "Squares mod p, the Legendre symbol, and quadratic reciprocity" },
  { href: "/reading/number-theory/numthy-07/", title: "Primitive Roots", desc: "Generators of cyclic groups and the discrete logarithm problem" },
  { href: "/reading/number-theory/numthy-08/", title: "Continued Fractions", desc: "Best rational approximations, periodic expansions, and Pell's equation" }
]} icon="#" iconClass="text-yellow-300 hover:text-yellow-200" />


    <p class="text-gray-500 text-sm mt-8">📺 Video lectures: <a href="https://ocw.mit.edu/courses/18-781-theory-of-numbers-spring-2012/">MIT 18.781 Theory of Numbers</a></p>

    <Neighbors>
    <ul class="neighbors">
      <li><a href="/reading/abstract-algebra/">🔗 Abstract Algebra</a> &mdash; modular arithmetic is integers mod n, a ring</li>
      <li><a href="/reading/cryptography/">🔐 Cryptography</a> &mdash; RSA is Euler's theorem applied</li>
      <li><a href="/reading/discrete-math/">🔢 Discrete Math</a> &mdash; divisibility and primes are discrete-math territory</li>
      <li><a href="/reading/algorithms/">⚙ Algorithms</a> &mdash; primality testing and GCD algorithms</li>
    </ul>
    </Neighbors>

  </main>
</Layout>
