---
import ChapterTable from "../../../components/ChapterTable.astro";
import Layout from '../../../layouts/Base.astro';
import Neighbors from "../../../components/Neighbors.astro";
---

<Layout title="Number Theory" favicon="#">
  <main>

    <a href="/reading/" class="text-sm mb-4 inline-block">&larr; back to reading</a>

    <h1># Number Theory</h1>
    <p class="text-gray-400 mb-2">Based on <a href="https://jheffero.w3.uvm.edu/numbertheory/">Jim Hefferon's Elementary Number Theory</a>, licensed <a href="https://www.gnu.org/licenses/fdl-1.3.html">GFDL</a> + <a href="https://creativecommons.org/licenses/by-sa/2.5/">CC BY-SA 2.5</a>.</p>
    <p class="text-gray-400 mb-6">From divisibility to continued fractions. Each chapter builds one layer of the integers' hidden structure, with runnable code and diagrams.</p>

    <!-- SVG: Sieve of Eratosthenes -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 400 200" class="w-full max-w-md" style="font-family: ui-monospace, monospace;">
        <text x="200" y="18" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.35">Sieve of Eratosthenes: primes highlighted</text>
        <!-- Grid of numbers 2-50, 7 per row -->
        <!-- Row 1: 2-8 -->
        <rect x="20" y="28" width="44" height="28" rx="3" fill="#facc15" fill-opacity="0.15"/>
        <text x="42" y="47" text-anchor="middle" fill="#facc15" font-size="13">2</text>
        <rect x="72" y="28" width="44" height="28" rx="3" fill="#facc15" fill-opacity="0.15"/>
        <text x="94" y="47" text-anchor="middle" fill="#facc15" font-size="13">3</text>
        <text x="146" y="47" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">4</text>
        <rect x="176" y="28" width="44" height="28" rx="3" fill="#facc15" fill-opacity="0.15"/>
        <text x="198" y="47" text-anchor="middle" fill="#facc15" font-size="13">5</text>
        <text x="250" y="47" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">6</text>
        <rect x="280" y="28" width="44" height="28" rx="3" fill="#facc15" fill-opacity="0.15"/>
        <text x="302" y="47" text-anchor="middle" fill="#facc15" font-size="13">7</text>
        <text x="354" y="47" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">8</text>
        <!-- Row 2: 9-15 -->
        <text x="42" y="82" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">9</text>
        <text x="94" y="82" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">10</text>
        <rect x="124" y="63" width="44" height="28" rx="3" fill="#facc15" fill-opacity="0.15"/>
        <text x="146" y="82" text-anchor="middle" fill="#facc15" font-size="13">11</text>
        <text x="198" y="82" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.2">12</text>
        <rect x="228" y="63" width="44" height="28" rx="3" fill="#facc15" fill-opacity="0.15"/>
        <text x="250" y="82" text-anchor="middle" fill="#facc15" font-size="13">13</text>
