        <text x="150" y="65" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.3">4</text>
        <line x1="180" y1="40" x2="180" y2="50" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
