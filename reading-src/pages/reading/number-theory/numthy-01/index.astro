        <text x="240" y="65" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.3">7</text>
        <line x1="270" y1="40" x2="270" y2="50" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <text x="270" y="65" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.3">8</text>
        <!-- 9: highlighted -->
        <circle cx="300" cy="45" r="10" fill="#facc15" fill-opacity="0.15"/>
        <line x1="300" y1="40" x2="300" y2="50" stroke="#facc15" stroke-width="1.5"/>
        <text x="300" y="65" text-anchor="middle" fill="#facc15" font-size="11">9</text>
