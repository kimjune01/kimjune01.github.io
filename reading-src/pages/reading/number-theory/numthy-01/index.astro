        <circle cx="210" cy="45" r="10" fill="#facc15" fill-opacity="0.15"/>
        <line x1="210" y1="40" x2="210" y2="50" stroke="#facc15" stroke-width="1.5"/>
        <text x="210" y="65" text-anchor="middle" fill="#facc15" font-size="11">6</text>
