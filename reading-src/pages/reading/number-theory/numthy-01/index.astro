        <line x1="90" y1="40" x2="90" y2="50" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <text x="90" y="65" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.3">2</text>
