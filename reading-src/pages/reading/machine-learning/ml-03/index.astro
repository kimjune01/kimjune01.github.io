<Layout title="Ch.3 — Optimization" favicon="🤖">
  <main>

    <a href="/reading/machine-learning/" class="text-sm mb-4 inline-block">&larr; back to machine learning</a>

    <h1>Optimization</h1>
    <p class="text-gray-400 text-sm mb-6">Deisenroth et al., <em>Mathematics for Machine Learning</em> (CC BY 4.0) &middot; <a href="https://mml-book.github.io/">mml-book.github.io</a></p>

    <div class="bg-zinc-800 rounded-lg p-5 mb-8 callout">
      <p class="text-lg" style="max-width:none"><strong>Gradient descent</strong> follows the negative gradient downhill. The <strong>learning rate</strong> controls step size: too small and you crawl, too large and you overshoot. <strong>Convex</strong> functions have one minimum, so gradient descent always finds it. Non-convex functions have many minima, and you get whichever one you fall into.</p>
    </div>

    <!-- SVG: contour plot with gradient arrows -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 360 280" class="w-full max-w-sm" style="font-family: ui-monospace, monospace;">
        <!-- Contour ellipses (centered at 200, 140) -->
        <ellipse cx="200" cy="140" rx="140" ry="100" fill="none" stroke="#60a5fa" stroke-width="0.8" stroke-opacity="0.15"/>
        <ellipse cx="200" cy="140" rx="110" ry="78" fill="none" stroke="#60a5fa" stroke-width="0.8" stroke-opacity="0.2"/>
        <ellipse cx="200" cy="140" rx="80" ry="56" fill="none" stroke="#60a5fa" stroke-width="0.8" stroke-opacity="0.25"/>
        <ellipse cx="200" cy="140" rx="50" ry="35" fill="none" stroke="#60a5fa" stroke-width="0.8" stroke-opacity="0.3"/>
        <ellipse cx="200" cy="140" rx="20" ry="14" fill="none" stroke="#60a5fa" stroke-width="0.8" stroke-opacity="0.4"/>
        <!-- Minimum point -->
        <circle cx="200" cy="140" r="3" fill="#34d399" fill-opacity="0.7"/>
        <text x="212" y="136" fill="#34d399" font-size="9" fill-opacity="0.6">min</text>
