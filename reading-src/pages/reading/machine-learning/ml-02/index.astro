        <line x1="260" y1="55" x2="260" y2="63" stroke="#34d399" stroke-width="1" stroke-opacity="0.5" stroke-dasharray="2,2"/>
        <circle cx="300" cy="48" r="3.5" fill="#f59e0b" fill-opacity="0.7"/>
