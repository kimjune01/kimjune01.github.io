        <text x="80" y="82" text-anchor="middle" fill="currentColor" font-size="11">A</text>
        <text x="80" y="132" text-anchor="middle" fill="currentColor" font-size="11">B</text>
        <text x="80" y="182" text-anchor="middle" fill="currentColor" font-size="11">C</text>
