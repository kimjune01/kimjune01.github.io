          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">Maximin</td><td class="pr-4 text-green-300">(maximin m)</td><td class="font-sans">Row player's best guaranteed minimum</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">Minimax</td><td class="pr-4 text-green-300">(minimax m)</td><td class="font-sans">Column player's least concession</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">Saddle point</td><td class="pr-4 text-green-300">(= (maximin m) (minimax m))</td><td class="font-sans">Pure equilibrium exists when they're equal</td></tr>
          <tr><td class="py-2 pr-4">Dominated</td><td class="pr-4 text-green-300">eliminated first</td><td class="font-sans">Strategies that are always worse than another</td></tr>
        </tbody>
      </table>
    </div>

