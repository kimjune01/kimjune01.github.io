        <line x1="420" y1="110" x2="620" y2="110" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
        <line x1="420" y1="165" x2="620" y2="165" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
        <line x1="420" y1="55" x2="420" y2="165" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
        <line x1="530" y1="55" x2="530" y2="165" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
        <line x1="620" y1="55" x2="620" y2="165" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
