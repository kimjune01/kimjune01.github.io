        <!-- Column headers -->
        <text x="160" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">Confess</text>
        <text x="250" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">Don't</text>
        <!-- Row headers -->
        <text x="55" y="90" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">Confess</text>
        <text x="55" y="140" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">Don't</text>
        <!-- Grid lines -->
        <line x1="90" y1="55" x2="290" y2="55" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
        <line x1="90" y1="110" x2="290" y2="110" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
        <line x1="90" y1="165" x2="290" y2="165" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
        <line x1="90" y1="55" x2="90" y2="165" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
        <line x1="200" y1="55" x2="200" y2="165" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
        <line x1="290" y1="55" x2="290" y2="165" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.3"/>
        <!-- Nash highlight on (Confess, Confess) -->
        <rect x="91" y="56" width="108" height="53" fill="#ef4444" fill-opacity="0.12" rx="2"/>
        <!-- Payoff values -->
        <text x="145" y="88" text-anchor="middle" fill="#ef4444" font-size="12" font-weight="bold">8, 8</text>
        <text x="245" y="88" text-anchor="middle" fill="currentColor" font-size="12">0.25, 10</text>
        <text x="145" y="143" text-anchor="middle" fill="currentColor" font-size="12">10, 0.25</text>
        <text x="245" y="143" text-anchor="middle" fill="currentColor" font-size="12">1, 1</text>
        <!-- Nash label -->
        <text x="145" y="102" text-anchor="middle" fill="#ef4444" font-size="8">Nash</text>
        <!-- Years label -->
        <text x="190" y="185" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.35">(years in prison, lower = better)</text>

        <!-- Chicken matrix -->
        <text x="480" y="20" text-anchor="middle" fill="currentColor" font-size="13" font-weight="bold">Chicken</text>
        <!-- Column headers -->
        <text x="480" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">Swerve</text>
        <text x="570" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">Straight</text>
        <!-- Row headers -->
        <text x="385" y="90" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">Swerve</text>
