        <text x="340" y="108" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.4">t=5</text>
        <!-- Dots for continuation -->
        <text x="390" y="84" fill="currentColor" font-size="14" fill-opacity="0.4">...</text>
        <!-- P1 choices (top) - all same for pure -->
        <text x="60" y="55" text-anchor="middle" fill="#60a5fa" font-size="11">R2</text>
        <text x="130" y="55" text-anchor="middle" fill="#60a5fa" font-size="11">R2</text>
        <text x="200" y="55" text-anchor="middle" fill="#60a5fa" font-size="11">R2</text>
        <text x="270" y="55" text-anchor="middle" fill="#60a5fa" font-size="11">R2</text>
