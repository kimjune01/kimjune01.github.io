        <circle cx="200" cy="80" r="4" fill="currentColor" fill-opacity="0.2" stroke="currentColor" stroke-width="1.2"/>
        <circle cx="270" cy="80" r="4" fill="currentColor" fill-opacity="0.2" stroke="currentColor" stroke-width="1.2"/>
        <circle cx="340" cy="80" r="4" fill="currentColor" fill-opacity="0.2" stroke="currentColor" stroke-width="1.2"/>
