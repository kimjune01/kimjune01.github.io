        <text x="130" y="108" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.4">t=2</text>
        <text x="200" y="108" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.4">t=3</text>
