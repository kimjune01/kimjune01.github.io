        <text x="170" y="77" fill="#f59e0b" font-size="9" fill-opacity="0.7">A</text>
        <!-- Asset B -->
        <circle cx="250" cy="45" r="4" fill="#f59e0b" fill-opacity="0.7"/>
        <text x="260" y="42" fill="#f59e0b" font-size="9" fill-opacity="0.7">B</text>
        <!-- Minimum variance portfolio -->
        <circle cx="80" cy="150" r="5" fill="#10b981" fill-opacity="0.7"/>
        <text x="95" y="148" fill="#10b981" font-size="9" fill-opacity="0.7">MVP</text>
