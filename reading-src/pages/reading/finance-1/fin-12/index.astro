        <text x="280" y="43" text-anchor="middle" fill="#f59e0b" font-size="9" fill-opacity="0.7">Credit</text>
        <text x="280" y="53" text-anchor="middle" fill="#f59e0b" font-size="9" fill-opacity="0.7">Risk</text>
