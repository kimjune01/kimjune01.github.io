        <text x="130" y="168" text-anchor="middle" fill="#ef4444" font-size="9" fill-opacity="0.7">Operational</text>
        <text x="130" y="178" text-anchor="middle" fill="#ef4444" font-size="9" fill-opacity="0.7">Risk</text>
        <line x1="147" y1="150" x2="167" y2="125" stroke="currentColor" stroke-width="1" stroke-opacity="0.2"/>
