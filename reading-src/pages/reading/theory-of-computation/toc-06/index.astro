    <!-- TM simulator -->
    <h3>Simulating a Turing machine</h3>
    <p>This TM recognizes a<sup>n</sup>b<sup>n</sup>c<sup>n</sup>: cross off one a, one b, one c per pass. If all are crossed off evenly, accept.</p>

    <SchemeRepl client:visible initialCode={`; Turing machine for a^n b^n c^n
; Strategy: repeatedly cross off one a, one b, one c.
; Accept if all symbols are crossed off.

(define (tm-anbncn input)
  (define tape (make-vector (+ (string-length input) 1) "_"))
  (let init ((i 0))
    (when (< i (string-length input))
      (vector-set! tape i (substring input i (+ i 1)))
      (init (+ i 1))))

  (define (find-and-cross ch start)
    (let loop ((i start))
      (cond
        ((>= i (vector-length tape)) #f)
        ((equal? (vector-ref tape i) ch)
         (vector-set! tape i "x") i)
        ((equal? (vector-ref tape i) "_") #f)
        (else (loop (+ i 1))))))

  (define (all-crossed?)
    (let loop ((i 0))
      (cond
        ((>= i (vector-length tape)) #t)
        ((equal? (vector-ref tape i) "x") (loop (+ i 1)))
        ((equal? (vector-ref tape i) "_") #t)
        (else #f))))

  (let outer ()
    (let ((a-pos (find-and-cross "a" 0)))
      (if (not a-pos)
          (all-crossed?)
          (let ((b-pos (find-and-cross "b" (+ a-pos 1))))
            (if (not b-pos) #f
                (let ((c-pos (find-and-cross "c" (+ b-pos 1))))
                  (if (not c-pos) #f
                      (outer)))))))))

(display "abc:       ") (display (tm-anbncn "abc")) (newline)
(display "aabbcc:    ") (display (tm-anbncn "aabbcc")) (newline)
(display "aaabbbccc: ") (display (tm-anbncn "aaabbbccc")) (newline)
(display "aabbc:     ") (display (tm-anbncn "aabbc")) (newline)
(display "ab:        ") (display (tm-anbncn "ab"))
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# Turing machine for a^n b^n c^n
def tm_anbncn(s):
    tape = list(s) + ['_']
    while True:
        # Find and cross off one 'a'
        a_pos = next((i for i, c in enumerate(tape) if c == 'a'), None)
        if a_pos is None:
            return all(c in ('x', '_') for c in tape)
        tape[a_pos] = 'x'
        # Find and cross off one 'b' after a
        b_pos = next((i for i in range(a_pos+1, len(tape)) if tape[i] == 'b'), None)
        if b_pos is None: return False
        tape[b_pos] = 'x'
        # Find and cross off one 'c' after b
        c_pos = next((i for i in range(b_pos+1, len(tape)) if tape[i] == 'c'), None)
        if c_pos is None: return False
        tape[c_pos] = 'x'

for s in ["abc", "aabbcc", "aaabbbccc", "aabbc", "ab"]:
    print(s.ljust(10) + ": " + str(tm_anbncn(s)))
`} />
