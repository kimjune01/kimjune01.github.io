        <text x="155" y="83" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.6">Bob</text>
        <text x="260" y="83" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.6">bob@db.io</text>
        <!-- Row 3 -->
        <text x="75" y="103" text-anchor="middle" fill="#f59e0b" font-size="10">3</text>
        <text x="155" y="103" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.6">Carol</text>
