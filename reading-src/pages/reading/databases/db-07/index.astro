        <rect x="148" y="107" width="40" height="20" rx="3" fill="#f87171" fill-opacity="0.15"/>
        <text x="170" y="121" text-anchor="middle" fill="#f87171" font-size="11">No</text>
        <rect x="210" y="107" width="40" height="20" rx="3" fill="#f87171" fill-opacity="0.15"/>
