        <text x="360" y="60" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.4">Peach</text>

        <!-- Arrow: quality direction -->
        <line x1="60" y1="85" x2="360" y2="85" stroke="currentColor" stroke-width="1" opacity="0.3"/>
        <polygon points="358,82 365,85 358,88" fill="currentColor" fill-opacity="0.3"/>
        <text x="210" y="100" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.4">increasing quality</text>

        <!-- Buyer's price line -->
