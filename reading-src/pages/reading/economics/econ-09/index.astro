            <th class="py-2 text-left">Example</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">First (perfect)</td><td class="pr-4">Unique price per buyer</td><td>Auctions, negotiated deals</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">Second (quantity)</td><td class="pr-4">Self-selecting menus</td><td>Bulk discounts, software tiers</td></tr>
          <tr><td class="py-2 pr-4">Third (segment)</td><td class="pr-4">Observable group membership</td><td>Student/senior discounts, airlines</td></tr>
        </tbody>
      </table>
    </div>


