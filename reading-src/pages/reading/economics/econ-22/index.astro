      <li><a href="https://en.wikipedia.org/wiki/Pareto_distribution"><img src="/reading/wikipedia.svg" alt="wp" style="display:inline;height:1em;vertical-align:-0.1em;margin-right:0.2em;"/>Pareto distribution</a></li>
      <li><a href="https://en.wikipedia.org/wiki/Wealth_inequality"><img src="/reading/wikipedia.svg" alt="wp" style="display:inline;height:1em;vertical-align:-0.1em;margin-right:0.2em;"/>Wealth inequality</a></li>
    </ul>
    </Neighbors>

    <PrevNext prev={{ href: "/reading/economics/econ-21/", label: "Behavioral Economics" }} next={{ href: "/reading/economics/econ-23/", label: "Comparative Systems" }} />

  </main>
</Layout>
