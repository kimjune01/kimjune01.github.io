            <th class="py-2 text-left">Meaning</th>
          </tr>
        </thead>
        <tbody class="text-gray-400">
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4 text-gray-300">Marginal utility</td><td>Additional satisfaction from one more unit</td></tr>
          <tr class="border-b border-zinc-800"><td class="py-2 pr-4 text-gray-300">Total utility</td><td>Cumulative satisfaction from all units consumed</td></tr>
          <tr><td class="py-2 pr-4 text-gray-300">Consumer surplus</td><td>Difference between willingness to pay and actual price</td></tr>
        </tbody>
      </table>
    </div>

