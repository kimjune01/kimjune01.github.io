      <li><a href="https://en.wikipedia.org/wiki/Consumer_surplus"><img src="/reading/wikipedia.svg" alt="wp" style="display:inline;height:1em;vertical-align:-0.1em;margin-right:0.2em;"/>W Consumer surplus</a></li>
    </ul>
    </Neighbors>

    <PrevNext prev={{ href: "/reading/economics/econ-05/", label: "Elasticity" }} next={{ href: "/reading/economics/econ-07/", label: "Opportunity Cost" }} />

  </main>
</Layout>
