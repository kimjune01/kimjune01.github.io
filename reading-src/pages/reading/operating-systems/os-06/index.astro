        <!-- Arrow: offset passes through unchanged -->
        <path d="M 107 80 Q 260 180 437 80" fill="none" stroke="#71717a" stroke-width="1" stroke-opacity="0.45" stroke-dasharray="4,3"/>
        <text x="260" y="168" text-anchor="middle" fill="currentColor" font-size="8" fill-opacity="0.25">offset unchanged</text>
      </svg>
    </div>

    <SchemeRepl client:visible initialCode={`; Page table: translate virtual address to physical address
; page-size = 4096 bytes (2^12)

(define page-size 4096)

; Page table: maps page number to frame number
(define page-table '((0 . 5) (1 . 2) (2 . 7) (3 . 0) (4 . 3)))

(define (translate virtual-addr)
  (let* ((page-num (quotient virtual-addr page-size))
         (offset (modulo virtual-addr page-size))
         (frame (cdr (assoc page-num page-table)))
         (physical (+ (* frame page-size) offset)))
    (display "Virtual: ") (display virtual-addr)
    (display " -> Page ") (display page-num)
    (display ", Offset ") (display offset)
    (display " -> Frame ") (display frame)
    (display " -> Physical: ") (display physical)
    (newline)))

(translate 0)       ; page 0, offset 0 -> frame 5
(translate 8192)    ; page 2, offset 0 -> frame 7
(translate 13000)   ; page 3, offset 808 -> frame 0
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# Virtual to physical address translation
PAGE_SIZE = 4096

page_table = {0: 5, 1: 2, 2: 7, 3: 0, 4: 3}

def translate(virtual_addr):
    page = virtual_addr // PAGE_SIZE
    offset = virtual_addr % PAGE_SIZE
    frame = page_table[page]
    physical = frame * PAGE_SIZE + offset
    print(f"V:{virtual_addr} -> Page {page}, Off {offset} -> Frame {frame} -> P:{physical}")

translate(0)
translate(8192)
translate(13000)
`} />
    </div>

    <h3>Translation Lookaside Buffer (TLB)</h3>
    <p>Every memory access requires a page table lookup, which is itself a memory access. The <strong>TLB</strong> is a small, fast hardware cache of recent page-to-frame mappings. TLB hit: one memory access. TLB miss: two (or more, with multi-level page tables).</p>

