        <rect x="340" y="20" width="130" height="30" rx="4" fill="none" stroke="#34d399" stroke-width="1.5" stroke-opacity="0.5"/>
        <text x="405" y="40" text-anchor="middle" fill="#34d399" font-size="10" fill-opacity="0.7">Physical Address</text>
