    <SchemeRepl client:visible initialCode={`; Simulate an inode-based file system
; Inode: (size permissions (direct-blocks ...) indirect-block)

(define (make-inode size perms direct indirect)
  (list size perms direct indirect))

(define (inode-size i) (car i))
(define (inode-direct i) (caddr i))
(define (inode-indirect i) (cadddr i))

; Directory: list of (name . inode-number)
(define root-dir '(("readme.txt" . 42) ("src" . 15) ("data.bin" . 87)))

; Inodes
(define inode-table
  (list (cons 42 (make-inode 13000 "rw-r--r--" '(8 14 23) '(31 45)))
        (cons 15 (make-inode 4096 "rwxr-xr-x" '(5) '()))
        (cons 87 (make-inode 50000 "rw-------" '(100 101 102) '(200 201 202 203)))))

(define (lookup name)
  (let ((entry (assoc name root-dir)))
    (if entry
        (let ((inode (cdr (assoc (cdr entry) inode-table))))
          (display "File: ") (display name) (newline)
          (display "  Inode: ") (display (cdr entry)) (newline)
          (display "  Size: ") (display (inode-size inode)) (newline)
          (display "  Direct blocks: ") (display (inode-direct inode)) (newline))
        (display "File not found"))))

(lookup "readme.txt")
(newline)
(lookup "data.bin")
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# Inode-based file system simulation
class Inode:
    def __init__(self, size, perms, direct, indirect=None):
        self.size = size
        self.perms = perms
        self.direct = direct
        self.indirect = indirect or []

inodes = {
    42: Inode(13000, "rw-r--r--", [8, 14, 23], [31, 45]),
    15: Inode(4096, "rwxr-xr-x", [5]),
    87: Inode(50000, "rw-------", [100, 101, 102], [200, 201, 202, 203]),
}

directory = {"readme.txt": 42, "src": 15, "data.bin": 87}

def ls():
    for name, ino in directory.items():
        inode = inodes[ino]
        blocks = len(inode.direct) + len(inode.indirect)
        print(f"{inode.perms}  {inode.size:>6}  {blocks} blocks  {name}")

ls()
`} />
