        <text x="10" y="15" fill="currentColor" font-size="10" fill-opacity="0.5">FIFO replacement (3 frames)</text>
        <text x="10" y="30" fill="currentColor" font-size="9" fill-opacity="0.35">Reference string: 7 0 1 2 0 3 0 4</text>

        <!-- Column headers -->
        <text x="60" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">7</text>
        <text x="115" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">0</text>
        <text x="170" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">1</text>
        <text x="225" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">2</text>
        <text x="280" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">0</text>
        <text x="335" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">3</text>
        <text x="390" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">0</text>
        <text x="445" y="50" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">4</text>

