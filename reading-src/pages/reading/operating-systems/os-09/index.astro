    <SchemeRepl client:visible initialCode={`; SCAN disk scheduling simulation
; Head starts at position, moves in one direction, then reverses

(define (scan-schedule requests start max-track)
  (let* ((sorted (sort requests <))
         (right (filter (lambda (r) (>= r start)) sorted))
         (left (filter (lambda (r) (< r start)) sorted))
         (order (append right (list max-track) (reverse left))))
    (display "Service order: ") (display order) (newline)
    ; Calculate total head movement
    (define (total-movement seq prev total)
      (if (null? seq) total
          (total-movement (cdr seq) (car seq)
                          (+ total (abs (- (car seq) prev))))))
    (let ((movement (total-movement order start 0)))
      (display "Total head movement: ") (display movement))))

(scan-schedule '(20 40 80 110 160) 50 199)
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# SCAN (elevator) disk scheduling
def scan(requests, start, max_track=199):
    right = sorted(r for r in requests if r >= start)
    left = sorted((r for r in requests if r < start), reverse=True)
    order = right + [max_track] + left

    movement = sum(abs(order[i] - (order[i-1] if i > 0 else start))
                   for i in range(len(order)))

    print(f"Service order: {order}")
    print(f"Total head movement: {movement}")

scan([20, 40, 80, 110, 160], start=50)
`} />
