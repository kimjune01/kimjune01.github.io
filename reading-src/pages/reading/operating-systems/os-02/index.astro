    <SchemeRepl client:visible initialCode={`; Round-robin scheduling simulation
; Each process: (name . burst-remaining)

(define (round-robin procs quantum)
  (define (step queue time log)
    (if (null? queue)
        log
        (let* ((proc (car queue))
               (name (car proc))
               (burst (cdr proc))
               (run (min burst quantum))
               (remaining (- burst run))
               (new-time (+ time run))
               (entry (string-append name ":["
                        (number->string time) "-"
                        (number->string new-time) "]")))
          (if (> remaining 0)
              (step (append (cdr queue) (list (cons name remaining)))
                    new-time
                    (append log (list entry)))
              (step (cdr queue)
                    new-time
                    (append log (list entry)))))))
  (step procs 0 '()))

(define procs (list (cons "P1" 4) (cons "P2" 3) (cons "P3" 5)))

(display "Round-Robin (quantum=2):") (newline)
(for-each (lambda (e) (display "  ") (display e) (newline))
          (round-robin procs 2))
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# Round-robin scheduling
from collections import deque

def round_robin(processes, quantum):
    queue = deque([(name, burst) for name, burst in processes])
    time = 0
    log = []
    while queue:
        name, burst = queue.popleft()
        run = min(burst, quantum)
        log.append(f"{name}:[{time}-{time+run}]")
        time += run
        if burst - run > 0:
            queue.append((name, burst - run))
    return log

procs = [("P1", 4), ("P2", 3), ("P3", 5)]
for entry in round_robin(procs, 2):
    print(f"  {entry}")
`} />
