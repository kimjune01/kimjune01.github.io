          <tr class="border-b border-zinc-800"><td class="py-2 pr-4">g . f</td><td class="pr-4 text-green-300">(compose g f)</td><td class="pr-4 text-blue-300">compose(g, f)</td><td class="font-sans">Composition: apply f then g</td></tr>
