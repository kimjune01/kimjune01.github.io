    <SchemeRepl client:visible initialCode={`; A monad = (M, return, join)
; return : a -> M(a)        — embed a pure value
; join   : M(M(a)) -> M(a)  — collapse one layer
;
; Maybe monad: M(a) = a | nothing
; return x = x              (just wrap it)
; join (Just (Just x)) = Just x
; join (Just Nothing)  = Nothing
; join Nothing         = Nothing

(define nothing 'nothing)
(define (just x) (list 'just x))
(define (just? x) (and (pair? x) (eq? (car x) 'just)))
(define (from-just x) (cadr x))

(define (maybe-return x) (just x))

(define (maybe-join mmx)
  (cond ((eq? mmx nothing) nothing)
        ((just? mmx)
         (let ((inner (from-just mmx)))
           (if (or (eq? inner nothing) (just? inner))
               inner
               nothing)))
        (else nothing)))

(display "join (Just (Just 5)): ")
(display (maybe-join (just (just 5)))) (newline)

(display "join (Just Nothing): ")
(display (maybe-join (just nothing))) (newline)

(display "join Nothing: ")
(display (maybe-join nothing))
; join peels off one layer. Two Justs become one. Nothing stays Nothing.
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# Maybe monad: return and join
def maybe_return(x):
    return ("just", x)

def maybe_join(mmx):
    if mmx is None or mmx == "nothing":
        return None
    tag, inner = mmx
    if tag == "just":
        return inner  # Just(Just(x)) -> Just(x), Just(None) -> None
    return None

print(f"join(Just(Just(5))): {maybe_join(('just', ('just', 5)))}")
print(f"join(Just(None)):    {maybe_join(('just', None))}")
print(f"join(None):          {maybe_join(None)}")
`} />
    </div>


    <!-- 2. Bind -->
    <h3>Bind: the programmer's interface</h3>
    <p><code>bind</code> (&gt;&gt;=) takes a monadic value M(a) and a function a &rarr; M(b), and produces M(b). Equivalent to join composed with fmap: <code>bind m f = join (fmap f m)</code>. Conversely, <code>join = bind id</code>. Bind is how programmers use monads: chain computations that produce effects.</p>

    <!-- SVG: Kleisli composition -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 400 120" class="w-full max-w-sm" style="font-family: ui-monospace, monospace;">
        <!-- a -->
        <text x="40" y="40" text-anchor="middle" fill="currentColor" font-size="14">a</text>
        <circle cx="40" cy="45" r="2" fill="currentColor" fill-opacity="0.4"/>

        <!-- b -->
        <text x="200" y="40" text-anchor="middle" fill="currentColor" font-size="14">b</text>
        <circle cx="200" cy="45" r="2" fill="currentColor" fill-opacity="0.4"/>

        <!-- c -->
        <text x="360" y="40" text-anchor="middle" fill="currentColor" font-size="14">c</text>
        <circle cx="360" cy="45" r="2" fill="currentColor" fill-opacity="0.4"/>

        <!-- Arrow f: a → M(b) -->
        <line x1="52" y1="42" x2="185" y2="42" stroke="currentColor" stroke-width="1.5"/>
        <polygon points="185,42 178,38 178,46" fill="currentColor"/>
        <text x="118" y="33" text-anchor="middle" fill="currentColor" font-size="11" fill-opacity="0.5">f : a &#x2192; M(b)</text>

        <!-- Arrow g: b → M(c) -->
        <line x1="212" y1="42" x2="345" y2="42" stroke="currentColor" stroke-width="1.5"/>
        <polygon points="345,42 338,38 338,46" fill="currentColor"/>
        <text x="278" y="33" text-anchor="middle" fill="currentColor" font-size="11" fill-opacity="0.5">g : b &#x2192; M(c)</text>

        <!-- Dashed arrow g >=> f: a → M(c) -->
        <path d="M 52 55 Q 200 100 345 55" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="5,3"/>
        <polygon points="345,55 338,52 340,59" fill="currentColor" fill-opacity="0.6"/>
        <text x="200" y="105" text-anchor="middle" fill="currentColor" font-size="11" fill-opacity="0.5">g &gt;=&gt; f : a &#x2192; M(c)</text>
