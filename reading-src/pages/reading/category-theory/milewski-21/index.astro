        <polygon points="282,184 290,192 280,190" fill="currentColor"/>
        <text x="255" y="100" text-anchor="middle" fill="currentColor" font-size="11" fill-opacity="0.5">Lan&#x2096;D</text>

        <!-- eta: 2-cell label (arrow direction reversed from epsilon) -->
