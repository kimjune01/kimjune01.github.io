        <text x="140" y="55" text-anchor="middle" fill="currentColor" font-size="14" fill-opacity="0.7">B</text>
        <text x="100" y="105" text-anchor="middle" fill="currentColor" font-size="12" fill-opacity="0.5">A &#x00D7; B (product)</text>
        <text x="100" y="120" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.3">a AND b</text>

        <!-- Sum: A + B -->
        <rect x="240" y="20" width="160" height="60" rx="6" fill="#a1a1aa" fill-opacity="0.15" stroke="currentColor" stroke-width="1.5"/>
