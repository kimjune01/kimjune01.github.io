    <SchemeRepl client:visible initialCode={`; cata : (F(a) -> a) -> Fix(F) -> a
; cata alg = alg . fmap (cata alg) . unfix

(define (cata fmap alg x)
  (alg (fmap (lambda (y) (cata fmap alg y))
             (unfix x))))

; Algebra 1: count — NatF(Int) -> Int
(define (count-alg x)
  (if (eq? (car x) 'zero) 0
      (+ 1 (cadr x))))

(display "cata count three: ")
(display (cata natf-map count-alg three)) (newline)
; 3

; Algebra 2: even? — NatF(Bool) -> Bool
(define (even-alg x)
  (if (eq? (car x) 'zero) #t
      (not (cadr x))))

(display "cata even? three: ")
(display (cata natf-map even-alg three)) (newline)
(display "cata even? two:   ")
(display (cata natf-map even-alg two)) (newline)

; Algebra 3: Fibonacci — NatF((Int,Int)) -> (Int,Int)
(define (fib-alg x)
  (if (eq? (car x) 'zero) (cons 1 1)
      (let ((pair (cadr x)))
        (cons (cdr pair) (+ (car pair) (cdr pair))))))

(display "fib(6): ")
(define six (succ (succ (succ three))))
(display (car (cata natf-map fib-alg six)))
; Same recursive structure, different algebras, different results.
; The catamorphism is the universal fold.
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# Catamorphism: the universal fold
def fix(x): return ("fix", x)
def unfix(x): return x[1]

def natf_map(f, x):
    if x[0] == "zero": return x
    return ("succ", f(x[1]))

def cata(fmap, alg, x):
    return alg(fmap(lambda y: cata(fmap, alg, y), unfix(x)))

# Build naturals
zero = fix(("zero",))
def succ(n): return fix(("succ", n))
three = succ(succ(succ(zero)))

# Count algebra
def count_alg(x):
    return 0 if x[0] == "zero" else 1 + x[1]

print(f"cata count 3: {cata(natf_map, count_alg, three)}")

# Fibonacci algebra
def fib_alg(x):
    if x[0] == "zero": return (1, 1)
    a, b = x[1]
    return (b, a + b)

six = succ(succ(succ(three)))
print(f"fib(6): {cata(natf_map, fib_alg, six)[0]}")
`} />
    </div>


    <!-- 4. Lists as initial algebra -->
    <h3>Lists as an initial algebra</h3>
    <p>Lists are the initial algebra of <code>ListF e a = Nil | Cons e a</code>. The catamorphism over ListF is <code>foldr</code>. Every fold you've written is a catamorphism.</p>

    <SchemeRepl client:visible initialCode={`; ListF e a = Nil | Cons(e, a)
; Represented as ('nil) or ('cons element rest)

(define (listf-map f x)
  (if (eq? (car x) 'nil) x
      (list 'cons (cadr x) (f (caddr x)))))

; Build a list: [10, 20, 30]
(define (fix-nil) (fix '(nil)))
(define (fix-cons e rest) (fix (list 'cons e rest)))

(define my-list
  (fix-cons 10 (fix-cons 20 (fix-cons 30 (fix-nil)))))

; Algebra 1: sum — ListF(Int, Int) -> Int
(define (sum-alg x)
  (if (eq? (car x) 'nil) 0
      (+ (cadr x) (caddr x))))

(display "sum [10,20,30]: ")
(display (cata listf-map sum-alg my-list)) (newline)

; Algebra 2: length — ListF(Int, Int) -> Int
(define (len-alg x)
  (if (eq? (car x) 'nil) 0
      (+ 1 (caddr x))))

(display "length [10,20,30]: ")
(display (cata listf-map len-alg my-list)) (newline)

; Algebra 3: collect to native list
(define (to-list-alg x)
  (if (eq? (car x) 'nil) '()
      (cons (cadr x) (caddr x))))

(display "to-list: ")
(display (cata listf-map to-list-alg my-list))
; foldr IS cata. Every fold is a catamorphism.
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# Lists as initial algebra of ListF
def listf_map(f, x):
    if x[0] == "nil": return x
    return ("cons", x[1], f(x[2]))

# Build [10, 20, 30]
nil = fix(("nil",))
my_list = fix(("cons", 10, fix(("cons", 20, fix(("cons", 30, nil))))))

def sum_alg(x):
    return 0 if x[0] == "nil" else x[1] + x[2]

def len_alg(x):
    return 0 if x[0] == "nil" else 1 + x[2]

def to_list_alg(x):
    return [] if x[0] == "nil" else [x[1]] + x[2]

print(f"sum [10,20,30]: {cata(listf_map, sum_alg, my_list)}")
print(f"length [10,20,30]: {cata(listf_map, len_alg, my_list)}")
print(f"to-list: {cata(listf_map, to_list_alg, my_list)}")
`} />
    </div>


    <!-- 5. Coalgebras and anamorphisms -->
    <h3>Coalgebras and anamorphisms — the dual</h3>
    <p>An <strong>F-coalgebra</strong> reverses the arrow: <code>a &rarr; F(a)</code>. Instead of collapsing structure, it generates it. The terminal coalgebra is the greatest fixed point. The <strong>anamorphism</strong> (unfold) is the unique morphism into the terminal coalgebra. In Haskell, the fixed point for both is <code>Fix f</code>, but conceptually: algebras consume, coalgebras produce.</p>

    <SchemeRepl client:visible initialCode={`; Anamorphism: unfold from a seed.
; ana : (a -> F(a)) -> a -> Fix(F)
; ana coalg = fix . fmap (ana coalg) . coalg

(define (ana fmap coalg seed)
  (fix (fmap (lambda (s) (ana fmap coalg s))
             (coalg seed))))

; Coalgebra: generate natural numbers from an int
; Int -> NatF(Int)
(define (nat-coalg n)
  (if (= n 0) '(zero)
      (list 'succ (- n 1))))

(display "ana 3: ")
(display (ana natf-map nat-coalg 3)) (newline)
; Builds the same structure as (succ (succ (succ zero)))

; Round trip: ana builds, cata tears down
(display "cata count (ana 5): ")
(display (cata natf-map count-alg (ana natf-map nat-coalg 5))) (newline)

; Coalgebra for lists: generate from a native list
(define (list-coalg xs)
  (if (null? xs) '(nil)
      (list 'cons (car xs) (cdr xs))))

(define built (ana listf-map list-coalg '(1 2 3)))
(display "round-trip [1,2,3]: ")
(display (cata listf-map to-list-alg built))
; ana . cata = identity on the fixed point.
`} />


    <!-- 6. Ring expressions -->
    <h3>Ring expressions — algebras as evaluators</h3>
    <p>F-algebras cleanly separate <em>syntax</em> from <em>semantics</em>. The functor defines the shape of expressions; different algebras over the same functor give different interpretations. Ring expressions can be evaluated to integers, pretty-printed to strings, or simplified, all by swapping the algebra.</p>

    <SchemeRepl client:visible initialCode={`; RingF: the functor for ring expressions
; RingF(a) = RZero | ROne | RAdd(a, a) | RMul(a, a) | RNeg(a)

(define (ringf-map f x)
  (case (car x)
    ((rzero) x)
    ((rone) x)
    ((radd) (list 'radd (f (cadr x)) (f (caddr x))))
    ((rmul) (list 'rmul (f (cadr x)) (f (caddr x))))
    ((rneg) (list 'rneg (f (cadr x))))))

; Build: (2 + 3) * -(1)
(define expr
  (fix (list 'rmul
    (fix (list 'radd
      (fix (list 'radd (fix '(rone)) (fix '(rone))))
      (fix (list 'radd (fix '(rone)) (fix (list 'radd (fix '(rone)) (fix '(rone))))))))
    (fix (list 'rneg (fix '(rone)))))))

; Algebra 1: evaluate to integer
(define (eval-ring x)
  (case (car x)
    ((rzero) 0) ((rone) 1)
    ((radd) (+ (cadr x) (caddr x)))
    ((rmul) (* (cadr x) (caddr x)))
    ((rneg) (- (cadr x)))))

(display "eval (2+3)*(-1): ")
(display (cata ringf-map eval-ring expr)) (newline)

; Algebra 2: pretty-print to string
(define (show-ring x)
  (case (car x)
    ((rzero) "0") ((rone) "1")
    ((radd) (string-append "(" (cadr x) "+" (caddr x) ")"))
    ((rmul) (string-append "(" (cadr x) "*" (caddr x) ")"))
    ((rneg) (string-append "-" (cadr x)))))

(display "show: ")
(display (cata ringf-map show-ring expr))
; Same structure, different algebra, different result.
`} />


