        <!-- Equation caption -->
        <text x="170" y="252" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.3">&#x3B1;_b &#x2218; F(f) = G(f) &#x2218; &#x3B1;_a</text>
