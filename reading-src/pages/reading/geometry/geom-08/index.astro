        <circle cx="150" cy="115" r="2.5" fill="#60a5fa" fill-opacity="0.5"/>

        <!-- Right convex set -->
        <ellipse cx="300" cy="120" rx="60" ry="45" fill="#f59e0b" fill-opacity="0.1" stroke="#f59e0b" stroke-width="1.5" stroke-opacity="0.4"/>
        <text x="300" y="125" text-anchor="middle" fill="#f59e0b" font-size="13" fill-opacity="0.7">B</text>
