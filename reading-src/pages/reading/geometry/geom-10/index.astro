        <!-- Voronoi edges (faint, from ch9) -->
        <line x1="100" y1="100" x2="175" y2="175" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45" stroke-dasharray="3,3"/>
        <line x1="175" y1="175" x2="250" y2="150" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45" stroke-dasharray="3,3"/>
        <line x1="250" y1="150" x2="200" y2="80" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45" stroke-dasharray="3,3"/>
        <line x1="0" y1="150" x2="100" y2="100" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45" stroke-dasharray="3,3"/>
        <line x1="200" y1="80" x2="200" y2="0" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45" stroke-dasharray="3,3"/>
        <line x1="175" y1="175" x2="150" y2="300" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45" stroke-dasharray="3,3"/>
