        <!-- Domain elements -->
        <circle cx="80" cy="55" r="4" fill="currentColor" fill-opacity="0.5"/>
        <text x="68" y="58" text-anchor="end" fill="currentColor" font-size="10" fill-opacity="0.5">a</text>
