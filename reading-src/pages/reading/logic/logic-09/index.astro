        <rect x="80" y="25" width="18" height="50" rx="2" fill="#a1a1aa" fill-opacity="0.18" stroke="currentColor" stroke-width="1" stroke-opacity="0.4" transform="rotate(-10, 89, 75)"/>
        <text x="89" y="95" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.4">n=1</text>
