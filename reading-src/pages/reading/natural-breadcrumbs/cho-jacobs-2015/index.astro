        <text x="330" y="62" text-anchor="middle" fill="currentColor" font-size="11" font-weight="bold">1+1</text>
        <text x="330" y="76" text-anchor="middle" fill="currentColor" font-size="8" fill-opacity="0.5">(yes/no)</text>

        <!-- State arrow: 1 → A (blue, top arc) -->
