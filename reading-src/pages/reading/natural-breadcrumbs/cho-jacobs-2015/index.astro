        <polygon points="307,45 314,52 305,53" fill="#4ade80"/>
        <text x="262" y="28" text-anchor="middle" fill="#4ade80" font-size="10" font-weight="bold">effect</text>
        <text x="262" y="40" text-anchor="middle" fill="#4ade80" font-size="8" fill-opacity="0.7">measurement</text>

        <!-- Duality indicator -->
        <line x1="120" y1="100" x2="260" y2="100" stroke="currentColor" stroke-width="0.5" stroke-dasharray="3,2" stroke-opacity="0.3"/>
        <text x="190" y="118" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.5">dual arrows: state prepares, effect tests</text>
        <text x="190" y="132" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.35">probability = state composed with effect</text>
      </svg>
