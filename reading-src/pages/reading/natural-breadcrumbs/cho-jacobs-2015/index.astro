        <polygon points="164,50 169,58 160,57" fill="#60a5fa"/>
        <text x="118" y="28" text-anchor="middle" fill="#60a5fa" font-size="10" font-weight="bold">state</text>
        <text x="118" y="40" text-anchor="middle" fill="#60a5fa" font-size="8" fill-opacity="0.7">preparation</text>

        <!-- Effect arrow: A → 1+1 (green, top arc) -->
