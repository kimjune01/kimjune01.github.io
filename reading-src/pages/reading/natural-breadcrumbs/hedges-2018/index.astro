        <!-- Input wire: X — enters at base upper -->
        <line x1="10" y1="40" x2="80" y2="40" stroke="currentColor" stroke-width="1.5"/>
        <text x="10" y="33" fill="currentColor" font-size="11" fill-opacity="0.5">X</text>
        <circle cx="80" cy="40" r="2.5" fill="currentColor" fill-opacity="0.4"/>
        <!-- Output wire: Y — exits at tip -->
