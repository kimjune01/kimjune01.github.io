        <text x="10" y="103" fill="currentColor" font-size="11" fill-opacity="0.5">R</text>
        <circle cx="80" cy="90" r="2.5" fill="currentColor" fill-opacity="0.4"/>
        <!-- Labels -->
        <text x="42" y="33" fill="currentColor" font-size="9" fill-opacity="0.35">observation</text>
        <text x="275" y="57" fill="currentColor" font-size="9" fill-opacity="0.35">action</text>
