def buyer(price):
    return "buy" if price < 50 else "pass"

def seller(demand):
    return 70 if demand == "high" else 30

print(f"buyer(30) = {buyer(30)}")
print(f"buyer(70) = {buyer(70)}")
print(f"seller('high') = {seller('high')}")
`} />
