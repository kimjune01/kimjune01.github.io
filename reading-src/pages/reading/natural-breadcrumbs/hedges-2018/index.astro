        <text x="270" y="59" fill="currentColor" font-size="10">1, 1</text>
        <!-- Deviation arrow — P1 tries C instead (highlighted red) -->
        <path d="M 58,15 C 58,-5 130,-5 130,25" fill="none" stroke="#ef4444" stroke-width="1.5" stroke-dasharray="4,3"/>
        <text x="95" y="-2" fill="#ef4444" font-size="9">deviate to C?</text>
        <!-- Deviation payoff -->
