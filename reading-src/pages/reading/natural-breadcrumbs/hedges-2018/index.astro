        <!-- Player 2 triangle -->
        <polygon points="40,85 40,145 110,115" fill="#a1a1aa" fill-opacity="0.15" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
        <text x="58" y="120" text-anchor="middle" fill="currentColor" font-size="11">P2</text>
        <!-- Actions: D, D -->
        <line x1="110" y1="45" x2="170" y2="45" stroke="currentColor" stroke-width="1.2"/>
        <text x="140" y="38" text-anchor="middle" fill="currentColor" font-size="10">D</text>
        <line x1="110" y1="115" x2="170" y2="115" stroke="currentColor" stroke-width="1.2"/>
        <text x="140" y="108" text-anchor="middle" fill="currentColor" font-size="10">D</text>
        <!-- Utility box -->
