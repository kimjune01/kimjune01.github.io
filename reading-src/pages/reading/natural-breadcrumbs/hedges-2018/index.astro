        <text x="140" y="72" text-anchor="middle" fill="#60a5fa" font-size="11">argmax</text>
        <!-- Valuation arrow: utility feeds into selection -->
        <line x1="80" y1="105" x2="100" y2="80" stroke="#60a5fa" stroke-width="1.2" stroke-dasharray="3,2"/>
        <text x="68" y="112" text-anchor="end" fill="#60a5fa" font-size="9" fill-opacity="0.7">valuation</text>
        <!-- Actions in -->
        <text x="100" y="48" text-anchor="middle" fill="currentColor" font-size="8" fill-opacity="0.4">low, med, high</text>
        <!-- Output: best action -->
        <line x1="180" y1="67" x2="250" y2="70" stroke="currentColor" stroke-width="1.2"/>
        <line x1="250" y1="70" x2="370" y2="70" stroke="currentColor" stroke-width="1.5"/>
        <text x="365" y="62" text-anchor="end" fill="currentColor" font-size="11" fill-opacity="0.5">best action</text>
        <!-- Input X -->
        <line x1="10" y1="40" x2="80" y2="40" stroke="currentColor" stroke-width="1.2"/>
        <text x="10" y="33" fill="currentColor" font-size="9" fill-opacity="0.5">X</text>
      </svg>
