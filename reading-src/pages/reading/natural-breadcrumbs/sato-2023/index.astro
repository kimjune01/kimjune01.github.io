        <polygon points="244,65 254,70 244,75" fill="currentColor"/>
        <text x="190" y="60" text-anchor="middle" fill="currentColor" font-size="11">D(P &#x2016; Q)</text>

        <!-- Enrichment annotation below -->
        <line x1="100" y1="115" x2="280" y2="115" stroke="currentColor" stroke-width="0.5" stroke-dasharray="3,2" stroke-opacity="0.4"/>
        <text x="190" y="132" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.5">hom-object is a number, not a set</text>
