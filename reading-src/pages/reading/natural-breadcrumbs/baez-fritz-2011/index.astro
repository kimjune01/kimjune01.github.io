        <rect x="55" y="35" width="18" height="70" rx="2" fill="#4ade80" fill-opacity="0.3" stroke="#4ade80" stroke-width="1"/>
        <rect x="80" y="65" width="18" height="40" rx="2" fill="#4ade80" fill-opacity="0.3" stroke="#4ade80" stroke-width="1"/>
        <rect x="105" y="80" width="18" height="25" rx="2" fill="#4ade80" fill-opacity="0.3" stroke="#4ade80" stroke-width="1"/>
        <!-- baseline -->
        <line x1="25" y1="105" x2="128" y2="105" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>

        <!-- Arrow: H functor -->
        <line x1="145" y1="70" x2="230" y2="70" stroke="currentColor" stroke-width="1.5"/>
        <polygon points="225,66 235,70 225,74" fill="currentColor"/>
        <text x="188" y="60" text-anchor="middle" fill="currentColor" font-size="12">H</text>

        <!-- Entropy value -->
        <rect x="250" y="45" width="80" height="50" rx="8" fill="#a1a1aa" fill-opacity="0.15" stroke="currentColor" stroke-width="1.5"/>
        <text x="290" y="75" text-anchor="middle" fill="#4ade80" font-size="14">1.85</text>
        <text x="290" y="40" fill="currentColor" font-size="11" fill-opacity="0.5">bits</text>

        <!-- Functoriality equation below -->
        <text x="220" y="130" text-anchor="middle" fill="currentColor" font-size="11" fill-opacity="0.6">H(f ; g) = H(f) + H(g | f)</text>
