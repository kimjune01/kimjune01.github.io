---
import ChapterTable from "../../../components/ChapterTable.astro";
import Layout from '../../../layouts/Base.astro';
import Neighbors from "../../../components/Neighbors.astro";
---

<Layout title="Abstract Algebra" favicon="🔗">
  <main>

    <a href="/reading/" class="text-sm mb-4 inline-block">&larr; back to reading</a>

    <h1>🔗 Abstract Algebra</h1>
    <p class="text-gray-400 mb-2">Based on <a href="http://abstract.ups.edu/">Tom Judson's <em>Abstract Algebra: Theory and Applications</em></a>, licensed <a href="https://www.gnu.org/licenses/fdl-1.3.html">GFDL</a>.</p>
    <p class="text-gray-400 mb-6">The structures underneath category theory: groups, rings, fields. Runnable Python, plain English, diagrams.</p>

    <!-- SVG: Cayley table for Z3 under addition mod 3 -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 280 280" class="w-full max-w-xs" style="font-family: ui-monospace, monospace;">
        <!-- Title -->
        <text x="140" y="20" text-anchor="middle" fill="currentColor" font-size="11" fill-opacity="0.4">Cayley table for Z&#x2083; under + mod 3</text>

        <!-- Grid lines -->
        <line x1="60" y1="40" x2="260" y2="40" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>
        <line x1="60" y1="90" x2="260" y2="90" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>
        <line x1="60" y1="140" x2="260" y2="140" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>
        <line x1="60" y1="190" x2="260" y2="190" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>
        <line x1="60" y1="240" x2="260" y2="240" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>

        <line x1="60" y1="40" x2="60" y2="240" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>
        <line x1="127" y1="40" x2="127" y2="240" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>
        <line x1="193" y1="40" x2="193" y2="240" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>
        <line x1="260" y1="40" x2="260" y2="240" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>

        <!-- Operation symbol -->
        <text x="30" y="70" text-anchor="middle" fill="currentColor" font-size="16" fill-opacity="0.5">+</text>

        <!-- Column headers -->
        <text x="93" y="70" text-anchor="middle" fill="#60a5fa" font-size="16">0</text>
        <text x="160" y="70" text-anchor="middle" fill="#60a5fa" font-size="16">1</text>
        <text x="227" y="70" text-anchor="middle" fill="#60a5fa" font-size="16">2</text>

        <!-- Row headers -->
        <text x="30" y="120" text-anchor="middle" fill="#60a5fa" font-size="16">0</text>
        <text x="30" y="170" text-anchor="middle" fill="#60a5fa" font-size="16">1</text>
        <text x="30" y="220" text-anchor="middle" fill="#60a5fa" font-size="16">2</text>

        <!-- Row 0: 0+0=0, 0+1=1, 0+2=2 -->
        <text x="93" y="120" text-anchor="middle" fill="#f59e0b" font-size="16">0</text>
        <text x="160" y="120" text-anchor="middle" fill="#f59e0b" font-size="16">1</text>
        <text x="227" y="120" text-anchor="middle" fill="#f59e0b" font-size="16">2</text>

        <!-- Row 1: 1+0=1, 1+1=2, 1+2=0 -->
        <text x="93" y="170" text-anchor="middle" fill="#f59e0b" font-size="16">1</text>
        <text x="160" y="170" text-anchor="middle" fill="#f59e0b" font-size="16">2</text>
        <text x="227" y="170" text-anchor="middle" fill="#f59e0b" font-size="16">0</text>

        <!-- Row 2: 2+0=2, 2+1=0, 2+2=1 -->
        <text x="93" y="220" text-anchor="middle" fill="#f59e0b" font-size="16">2</text>
        <text x="160" y="220" text-anchor="middle" fill="#f59e0b" font-size="16">0</text>
        <text x="227" y="220" text-anchor="middle" fill="#f59e0b" font-size="16">1</text>

        <!-- Caption -->
        <text x="140" y="265" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.35">Every row and column is a permutation. That is a group.</text>
      </svg>
    </div>

    <ChapterTable chapters={[
  { href: "/reading/abstract-algebra/judson-01/", title: "Groups", desc: "A set with one operation that is closed, associative, has an identity, and has inverses" },
  { href: "/reading/abstract-algebra/judson-02/", title: "Subgroups", desc: "Cyclic groups generated by one element, and two tests for when a subset is itself a group" },
  { href: "/reading/abstract-algebra/judson-03/", title: "Homomorphisms", desc: "Functions between groups that preserve the operation, and the kernel that measures what they forget" },
  { href: "/reading/abstract-algebra/judson-04/", title: "Isomorphisms", desc: "A bijective homomorphism says two groups are the same structure wearing different labels" },
  { href: "/reading/abstract-algebra/judson-05/", title: "Cosets and Lagrange's Theorem", desc: "Subgroups partition a group into equal-sized cosets, so subgroup order divides group order" },
  { href: "/reading/abstract-algebra/judson-06/", title: "Rings", desc: "Two operations, addition and multiplication, with ideals playing the role of normal subgroups" },
  { href: "/reading/abstract-algebra/judson-07/", title: "Integral Domains and Fields", desc: "Rings where cancellation works, and fields where every nonzero element has a multiplicative inverse" },
  { href: "/reading/abstract-algebra/judson-08/", title: "Lattices and Boolean Algebras", desc: "Partial orders with meets and joins, connecting algebra to logic and set theory" }
]} icon="🔗" />


    <p class="text-gray-500 text-sm mt-8">📺 Video lectures: <a href="https://ocw.mit.edu/courses/18-703-modern-algebra-spring-2013/">MIT 18.703 Modern Algebra</a></p>

    <Neighbors>
    <ul class="neighbors">
      <li><a href="/reading/category-theory/">🐱 Category Theory</a> &mdash; groups, rings, and monoids reappear as objects in a category</li>
      <li><a href="/reading/number-theory/">&#35; Number Theory</a> &mdash; modular arithmetic is the integers mod n</li>
      <li><a href="/reading/cryptography/">🔐 Cryptography</a> &mdash; RSA and elliptic curves are applied abstract algebra</li>
      <li><a href="/reading/linear-algebra/">📐 Linear Algebra</a> &mdash; vector spaces are a special case of modules</li>
    </ul>
    </Neighbors>

  </main>
</Layout>
