        <circle cx="460" cy="170" r="5" fill="#ef4444" fill-opacity="0.4" stroke="#ef4444" stroke-width="1"/>
        <text x="472" y="174" fill="#ef4444" font-size="8" fill-opacity="0.7">eliminated</text>

