        <!-- Single arrow from scientist to conclusion -->
        <circle cx="40" cy="110" r="14" fill="#a1a1aa" fill-opacity="0.15" stroke="currentColor" stroke-width="1.5"/>
        <text x="40" y="114" text-anchor="middle" fill="currentColor" font-size="10">S</text>

        <line x1="54" y1="110" x2="185" y2="110" stroke="currentColor" stroke-width="1.5" marker-end="url(#arrowC)"/>

        <!-- Blinders (dashed lines showing ignored data) -->
        <circle cx="130" cy="60" r="4" fill="#a1a1aa" fill-opacity="0.18"/>
        <text x="142" y="64" fill="currentColor" font-size="8" fill-opacity="0.35">ignored</text>
