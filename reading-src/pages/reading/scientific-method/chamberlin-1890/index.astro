        <text x="210" y="114" text-anchor="middle" fill="currentColor" font-size="10">H</text>

        <text x="120" y="210" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.35">confirmation bias: data that fits is kept, the rest is invisible</text>

        <!-- Divider -->
        <line x1="260" y1="20" x2="260" y2="230" stroke="#71717a" stroke-width="0.5" stroke-opacity="0.45"/>

        <!-- Right: multiple working hypotheses -->
        <text x="395" y="20" text-anchor="middle" fill="currentColor" font-size="11" fill-opacity="0.5">multiple hypotheses</text>

        <!-- Fan of arrows from scientist to hypotheses -->
