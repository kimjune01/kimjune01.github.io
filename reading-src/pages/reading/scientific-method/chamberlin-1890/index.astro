        <text x="300" y="114" text-anchor="middle" fill="currentColor" font-size="10">S</text>

        <!-- H1 -->
        <line x1="314" y1="104" x2="400" y2="50" stroke="currentColor" stroke-width="1.2"/>
        <rect x="400" y="34" width="40" height="32" rx="5" fill="#a1a1aa" fill-opacity="0.15" stroke="currentColor" stroke-width="1.2"/>
        <text x="420" y="54" text-anchor="middle" fill="currentColor" font-size="9">H1</text>

        <!-- H2 -->
        <line x1="314" y1="110" x2="400" y2="110" stroke="currentColor" stroke-width="1.2"/>
        <rect x="400" y="94" width="40" height="32" rx="5" fill="#a1a1aa" fill-opacity="0.15" stroke="currentColor" stroke-width="1.2"/>
        <text x="420" y="114" text-anchor="middle" fill="currentColor" font-size="9">H2</text>

