---
import ChapterTable from "../../../components/ChapterTable.astro";
import Layout from '../../../layouts/Base.astro';
import Neighbors from "../../../components/Neighbors.astro";
---

<Layout title="Statistics" favicon="📊">
  <main>

    <a href="/reading/" class="text-sm mb-4 inline-block">&larr; back to reading</a>

    <h1>📊 Statistics</h1>
    <p class="text-gray-400 mb-2">Based on <a href="https://openintro.org/book/operating-systems/">OpenIntro Statistics</a>, licensed <a href="https://creativecommons.org/licenses/by-sa/3.0/">CC BY-SA 3.0</a>.</p>
    <p class="text-gray-400 mb-6">Data analysis and inference, translated into runnable Python with diagrams.</p>

    <!-- SVG: Normal distribution bell curve with shaded 95% CI -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 400 160" class="w-full max-w-md" style="font-family: ui-monospace, monospace;">
        <!-- Axes -->
        <line x1="30" y1="130" x2="370" y2="130" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <!-- Bell curve path (standard normal, scaled) -->
        <path d="M 30,130 Q 60,128 80,125 Q 100,118 120,105 Q 140,82 160,55 Q 180,28 200,20 Q 220,28 240,55 Q 260,82 280,105 Q 300,118 320,125 Q 340,128 370,130" fill="none" stroke="currentColor" stroke-width="2" stroke-opacity="0.7"/>
        <!-- Shaded 95% CI region (approx -1.96 to +1.96 sigma) -->
        <path d="M 108,112 Q 120,105 140,82 Q 160,55 180,28 Q 200,20 220,28 Q 240,55 260,82 Q 280,105 292,112 L 292,130 L 108,130 Z" fill="#3b82f6" fill-opacity="0.2"/>
        <!-- Boundary lines at -1.96 and +1.96 sigma -->
        <line x1="108" y1="112" x2="108" y2="130" stroke="#3b82f6" stroke-width="1" stroke-dasharray="3,2" stroke-opacity="0.5"/>
        <line x1="292" y1="112" x2="292" y2="130" stroke="#3b82f6" stroke-width="1" stroke-dasharray="3,2" stroke-opacity="0.5"/>
        <!-- Labels -->
        <text x="200" y="80" text-anchor="middle" fill="#3b82f6" font-size="11" fill-opacity="0.7">95%</text>
        <text x="108" y="145" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.4">-1.96&#x3c3;</text>
        <text x="200" y="145" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.4">&#x3bc;</text>
        <text x="292" y="145" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.4">+1.96&#x3c3;</text>
        <!-- Caption -->
        <text x="200" y="158" text-anchor="middle" fill="currentColor" font-size="9" fill-opacity="0.3">Normal distribution with 95% confidence interval</text>
      </svg>
    </div>

    <ChapterTable chapters={[
  { href: "/reading/statistics/openintro-01/", title: "Introduction to Data", desc: "Observations, variables, study design, and sampling strategies" },
  { href: "/reading/statistics/openintro-02/", title: "Summarizing Data", desc: "Histograms, box plots, measures of center and spread, contingency tables" },
  { href: "/reading/statistics/openintro-03/", title: "Probability", desc: "Rules, conditional probability, Bayes' theorem, independence" },
  { href: "/reading/statistics/openintro-04/", title: "Distributions", desc: "Normal, binomial, Poisson, and geometric distributions with Z-scores" },
  { href: "/reading/statistics/openintro-05/", title: "Foundations for Inference", desc: "Point estimates, confidence intervals, hypothesis testing, p-values" }
]} icon="📊" iconClass="text-yellow-300 hover:text-yellow-200" />


    <p class="text-gray-500 text-sm mt-8">📺 Video lectures: <a href="https://www.youtube.com/user/joshstarmer">StatQuest with Josh Starmer</a></p>

    <Neighbors>
    <ul class="neighbors">
      <li><a href="/reading/probability/">🎰 Probability</a> &mdash; statistics applies probability theory to data</li>
      <li><a href="/reading/scientific-method/">🔬 Scientific Method</a> &mdash; p-values, significance, and replication live here</li>
      <li><a href="/reading/machine-learning/">🤖 Machine Learning</a> &mdash; regression and classification as statistical inference</li>
      <li><a href="/reading/information-theory/">📡 Information Theory</a> &mdash; KL divergence appears in both fields</li>
    </ul>
    </Neighbors>

  </main>
</Layout>
