        <text x="40" y="20" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.7">P</text>
        <text x="100" y="20" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.7">Q</text>
        <text x="200" y="20" text-anchor="middle" fill="currentColor" font-size="13" fill-opacity="0.7">P &#x2192; Q</text>
