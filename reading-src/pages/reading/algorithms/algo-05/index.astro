    <h3>Binary search tree</h3>
    <p>Insert, search, and delete all follow the same path from root to leaf. Average depth O(log n) for random insertions. Worst case O(n) for sorted input.</p>

    <SchemeRepl client:visible initialCode={`; BST: insert and search
; Tree = () | (key left right)

(define (make-node key) (list key (list) (list)))
(define (node-key t) (car t))
(define (node-left t) (cadr t))
(define (node-right t) (caddr t))

(define (bst-insert tree key)
  (cond ((null? tree) (make-node key))
        ((< key (node-key tree))
         (list (node-key tree)
               (bst-insert (node-left tree) key)
               (node-right tree)))
        ((> key (node-key tree))
         (list (node-key tree)
               (node-left tree)
               (bst-insert (node-right tree) key)))
        (else tree)))

(define (bst-search tree key)
  (cond ((null? tree) #f)
        ((= key (node-key tree)) #t)
        ((< key (node-key tree)) (bst-search (node-left tree) key))
        (else (bst-search (node-right tree) key))))

(define t (list))
(set! t (bst-insert t 20))
(set! t (bst-insert t 10))
(set! t (bst-insert t 30))
(set! t (bst-insert t 5))
(set! t (bst-insert t 15))

(display "Search 15: ") (display (bst-search t 15)) (newline)
(display "Search 25: ") (display (bst-search t 25))
`} />

    <div class="python-block my-2" style="display:none">
      <Repl client:visible initialCode={`# BST in Python
class Node:
    def __init__(self, key):
        self.key = key
        self.left = None
        self.right = None

def insert(root, key):
    if root is None: return Node(key)
    if key < root.key: root.left = insert(root.left, key)
    elif key > root.key: root.right = insert(root.right, key)
    return root

def search(root, key):
    if root is None: return False
    if key == root.key: return True
    if key < root.key: return search(root.left, key)
    return search(root.right, key)

def inorder(root):
    if root is None: return []
    return inorder(root.left) + [root.key] + inorder(root.right)

root = None
for k in [20, 10, 30, 5, 15, 25, 35]:
    root = insert(root, k)

print(f"Inorder: {inorder(root)}")
print(f"Search 15: {search(root, 15)}")
print(f"Search 25: {search(root, 25)}")
`} />
    </div>

    <h3>Tree traversals</h3>
    <p><strong>Inorder</strong> (left, root, right) gives sorted output. <strong>Preorder</strong> (root, left, right) gives a serialization that can reconstruct the tree. <strong>Postorder</strong> (left, right, root) evaluates expressions bottom-up.</p>

    <SchemeRepl client:visible initialCode={`; Three traversals of the same tree
; Tree: (key left right)

(define tree
  (list 20
    (list 10 (list 5 (list) (list)) (list 15 (list) (list)))
    (list 30 (list 25 (list) (list)) (list 35 (list) (list)))))

(define (inorder t)
  (if (null? t) (list)
      (append (inorder (cadr t))
              (list (car t))
              (inorder (caddr t)))))

(define (preorder t)
  (if (null? t) (list)
      (append (list (car t))
              (preorder (cadr t))
              (preorder (caddr t)))))

(define (postorder t)
  (if (null? t) (list)
      (append (postorder (cadr t))
              (postorder (caddr t))
              (list (car t)))))

(display "Inorder:   ") (display (inorder tree)) (newline)
(display "Preorder:  ") (display (preorder tree)) (newline)
(display "Postorder: ") (display (postorder tree))
`} />

