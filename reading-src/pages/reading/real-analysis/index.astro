---
import ChapterTable from "../../../components/ChapterTable.astro";
import Layout from '../../../layouts/Base.astro';
import Neighbors from "../../../components/Neighbors.astro";
---

<Layout title="Real Analysis" favicon="∞">
  <main>

    <a href="/reading/" class="text-sm mb-4 inline-block">← back to reading</a>

    <h1>∞ Real Analysis</h1>
    <p class="text-gray-400 mb-2">Based on <a href="https://www.jirka.org/ra/">Jiří Lebl, "Basic Analysis I"</a>, licensed <a href="https://creativecommons.org/licenses/by-sa/4.0/">CC BY-SA 4.0</a>.</p>
    <p class="text-gray-400 mb-6">The rigorous foundation beneath calculus: limits, continuity, convergence, and integration, built from the axioms of the real numbers. Translated into runnable code with diagrams.</p>

    <!-- SVG: Epsilon-delta diagram -->
    <div class="flex justify-center my-6">
      <svg viewBox="0 0 400 240" class="w-full max-w-md" style="font-family: ui-monospace, monospace;">
        <!-- Axes -->
        <line x1="40" y1="200" x2="380" y2="200" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <line x1="40" y1="200" x2="40" y2="20" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <!-- Curve y = f(x) -->
        <path d="M 60 170 Q 120 140 180 100 Q 240 60 300 50 Q 340 45 370 55" fill="none" stroke="#60a5fa" stroke-width="2" stroke-opacity="0.7"/>
        <!-- Point c on x-axis -->
        <line x1="200" y1="200" x2="200" y2="205" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.5"/>
        <text x="200" y="218" text-anchor="middle" fill="currentColor" font-size="12" fill-opacity="0.6">c</text>
        <!-- Point (c, f(c)) on curve -->
        <circle cx="200" cy="88" r="3.5" fill="#f59e0b" fill-opacity="0.8"/>
        <!-- f(c) on y-axis -->
        <line x1="35" y1="88" x2="40" y2="88" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.5"/>
        <text x="28" y="92" text-anchor="end" fill="currentColor" font-size="11" fill-opacity="0.6">f(c)</text>
        <!-- Delta band (vertical) -->
        <rect x="160" y="20" width="80" height="180" fill="#60a5fa" fill-opacity="0.08" stroke="#60a5fa" stroke-width="1" stroke-dasharray="4,3" stroke-opacity="0.3"/>
        <text x="160" y="218" text-anchor="middle" fill="#60a5fa" font-size="10" fill-opacity="0.5">c-δ</text>
        <text x="240" y="218" text-anchor="middle" fill="#60a5fa" font-size="10" fill-opacity="0.5">c+δ</text>
        <!-- Epsilon band (horizontal) -->
        <rect x="40" y="68" width="340" height="40" fill="#f59e0b" fill-opacity="0.06" stroke="#f59e0b" stroke-width="1" stroke-dasharray="4,3" stroke-opacity="0.3"/>
        <text x="28" y="72" text-anchor="end" fill="#f59e0b" font-size="10" fill-opacity="0.5">f(c)+ε</text>
        <text x="28" y="112" text-anchor="end" fill="#f59e0b" font-size="10" fill-opacity="0.5">f(c)-ε</text>
        <!-- Caption -->
        <text x="200" y="235" text-anchor="middle" fill="currentColor" font-size="10" fill-opacity="0.3">For every ε, there exists δ. That is continuity.</text>
      </svg>
    </div>

    <ChapterTable chapters={[
  { href: "/reading/real-analysis/lebl-01/", title: "Real Numbers", desc: "The axioms, completeness, supremum, and why the rationals aren't enough" },
  { href: "/reading/real-analysis/lebl-02/", title: "Sequences", desc: "Convergence, monotone sequences, Bolzano-Weierstrass, and Cauchy completeness" },
  { href: "/reading/real-analysis/lebl-03/", title: "Series", desc: "When infinite sums converge: comparison, ratio, root tests, and power series" },
  { href: "/reading/real-analysis/lebl-04/", title: "Continuous Functions", desc: "Epsilon-delta continuity, IVT, EVT, and uniform continuity" },
  { href: "/reading/real-analysis/lebl-05/", title: "The Derivative", desc: "Definition, chain rule, mean value theorem, L'Hopital, and Taylor's theorem" },
  { href: "/reading/real-analysis/lebl-06/", title: "The Riemann Integral", desc: "Partitions, upper/lower sums, integrability, and the fundamental theorem" },
  { href: "/reading/real-analysis/lebl-07/", title: "Sequences of Functions", desc: "Pointwise vs uniform convergence, interchange of limits, Weierstrass M-test" },
  { href: "/reading/real-analysis/lebl-08/", title: "Metric Spaces", desc: "Open/closed sets, compactness, connectedness, and completeness in the abstract" }
]} icon="∞" iconClass="text-yellow-300 hover:text-yellow-200" />


    <p class="text-gray-500 text-sm mt-8">📺 Video lectures: <a href="https://ocw.mit.edu/courses/18-100b-real-analysis-spring-2025/">MIT 18.100B Real Analysis</a></p>

    <Neighbors>
    <ul class="neighbors">
      <li><a href="/reading/calculus/">∫ Calculus</a> — real analysis proves what calculus does</li>
      <li><a href="/reading/proof-writing/">✎ Proofs</a> — epsilon-delta arguments are the proof technique here</li>
      <li><a href="/reading/probability/">🎰 Probability</a> — measure theory extends real analysis to probability</li>
      <li><a href="/reading/geometry/">△ Geometry</a> — metric spaces appear in both real analysis and geometry</li>
    </ul>
    </Neighbors>
  </main>
</Layout>
