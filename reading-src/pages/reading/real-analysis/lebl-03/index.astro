        <text x="35" y="30" text-anchor="end" fill="currentColor" font-size="10" fill-opacity="0.4">S_n</text>
        <!-- Limit line -->
        <line x1="40" y1="50" x2="380" y2="50" stroke="#f59e0b" stroke-width="1" stroke-dasharray="4,3" stroke-opacity="0.4"/>
        <text x="385" y="54" fill="#f59e0b" font-size="10" fill-opacity="0.6">S</text>
        <!-- Partial sum points (geometric series sum 1/2^k) -->
        <!-- S_1=0.5, S_2=0.75, S_3=0.875, ... approaching 1 -->
