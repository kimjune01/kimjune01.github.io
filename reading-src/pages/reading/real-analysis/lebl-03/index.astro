        <circle cx="110" cy="75" r="3" fill="#60a5fa" fill-opacity="0.7"/>
        <circle cx="150" cy="62" r="3" fill="#60a5fa" fill-opacity="0.7"/>
        <circle cx="190" cy="56" r="3" fill="#60a5fa" fill-opacity="0.7"/>
        <circle cx="230" cy="53" r="3" fill="#60a5fa" fill-opacity="0.7"/>
