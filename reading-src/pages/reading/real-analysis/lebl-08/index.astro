        <circle cx="180" cy="100" r="2" fill="currentColor" fill-opacity="0.3"/>
        <circle cx="145" cy="155" r="2" fill="currentColor" fill-opacity="0.3"/>
        <!-- Point outside -->
        <circle cx="250" cy="80" r="2" fill="#a1a1aa" fill-opacity="0.18"/>
        <!-- Label -->
        <text x="150" y="215" text-anchor="middle" fill="#60a5fa" font-size="11" fill-opacity="0.5">B(p, r)</text>
        <!-- Caption -->
