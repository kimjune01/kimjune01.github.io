        <text x="158" y="117" fill="#f59e0b" font-size="12" fill-opacity="0.7">p</text>
        <!-- Radius line -->
        <line x1="150" y1="120" x2="220" y2="85" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
        <text x="192" y="95" fill="currentColor" font-size="11" fill-opacity="0.5">r</text>
        <!-- Points inside -->
        <circle cx="130" cy="100" r="2" fill="currentColor" fill-opacity="0.3"/>
        <circle cx="170" cy="140" r="2" fill="currentColor" fill-opacity="0.3"/>
