        <circle cx="130" cy="47" r="3" fill="#60a5fa" fill-opacity="0.7"/>
        <circle cx="160" cy="93" r="3" fill="#60a5fa" fill-opacity="0.7"/>
        <circle cx="190" cy="55" r="3" fill="#60a5fa" fill-opacity="0.7"/>
        <circle cx="220" cy="85" r="3" fill="#60a5fa" fill-opacity="0.7"/>
        <circle cx="250" cy="62" r="3" fill="#60a5fa" fill-opacity="0.7"/>
        <circle cx="280" cy="78" r="3" fill="#60a5fa" fill-opacity="0.7"/>
        <circle cx="310" cy="66" r="3" fill="#60a5fa" fill-opacity="0.7"/>
        <circle cx="340" cy="74" r="3" fill="#60a5fa" fill-opacity="0.7"/>
