        <!-- Limit line L -->
        <line x1="40" y1="70" x2="380" y2="70" stroke="#f59e0b" stroke-width="1" stroke-dasharray="4,3" stroke-opacity="0.4"/>
        <text x="35" y="74" text-anchor="end" fill="#f59e0b" font-size="11" fill-opacity="0.6">L</text>
        <!-- Epsilon band -->
        <rect x="40" y="55" width="340" height="30" fill="#f59e0b" fill-opacity="0.06"/>
        <text x="35" y="58" text-anchor="end" fill="#f59e0b" font-size="9" fill-opacity="0.4">L+ε</text>
