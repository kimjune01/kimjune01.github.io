    <span class="hl-keyword">if</span> <span class="hl-keyword">not</span> entry.data_split:
        failures.append(
            <span class="hl-string">"Q9 (Peirce): No data split declared. "</span>
            <span class="hl-string">"The hypothesis may have been generated from the test data. "</span>
            <span class="hl-string">"Specify which data was used for generation and which for testing."</span>
